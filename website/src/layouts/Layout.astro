---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Al Karam Real Estate - Your trusted real estate partner in Al Noor Orchard & Al Jalil Garden, Lahore. Authorized sub-dealer of Al Jalil Developers." />
  <meta name="keywords" content="Al Karam Real Estate, Al Jalil Garden, Al Noor Orchard, Lahore real estate, plots in Lahore, Al Jalil Developers" />
  <link rel="icon" type="image/x-icon" href="/images/logo.jpg" />
  <title>{title}</title>
  <style>
    /* CRITICAL: applied before any JS or CSS loads */
    html, body { overflow-x: hidden !important; }
    html { scrollbar-gutter: stable; }
    /* Cursor elements parked off-screen before JS moves them */
    #cursor-dot, #cursor-ring {
      position: fixed !important;
      top: -200px !important;
      left: -200px !important;
      pointer-events: none !important;
    }
    /* Hamburger always visible on mobile — critical rule fires before all CSS */
    @media (max-width: 768px) {
      .hamburger {
        display: flex !important;
        z-index: 1002 !important;
      }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
