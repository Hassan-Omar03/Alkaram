#ceo .ceo-role,
#ceo .ceo-value,
#ceo .value-icon,
#ceo .ceo-info .section-title,
#testimonials .testimonials-header h2,
#testimonials .testimonials-header .section-label,
#testimonials .testimonials-header .accent-line,
#testimonials .testimonial-card {
  opacity: 1 !important;
  transform: none !important;
  filter: none !important;
}

/* Fast reveal — 0.15s snap-in instead of 0.4s slow rise */
.reveal {
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 0.15s ease, transform 0.15s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
/* ── FAST CSS TEXT ANIMATIONS (play immediately, no scroll delay) ── */
@keyframes hdrUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes hdrDown {
  from { opacity: 0; transform: translateY(-12px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes lineGrow {
  from { transform: scaleX(0); opacity: 0; transform-origin: left; }
  to   { transform: scaleX(1); opacity: 1; }
}
@keyframes labelShimmer {
  0%,100% { color: var(--blue-light); }
  50%     { color: var(--blue-lighter); text-shadow: 0 0 10px rgba(139,190,240,0.5); }
}
@keyframes accentShimmer {
  0%   { background-position: 0% 0%; }
  100% { background-position: 200% 0%; }
}
@keyframes accentPulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(61,126,199,0); }
  50%     { box-shadow: 0 0 6px 2px rgba(61,126,199,0.3); }
}

/* Section label: fast drop-in + periodic shimmer */
.section-label {
  animation: hdrDown 0.22s ease both, labelShimmer 3s ease 0.8s infinite;
}
/* Section title: fast rise */
.section-title  { animation: hdrUp 0.25s ease 0.05s both; }
.section-title:hover { text-shadow: 0 2px 20px rgba(255,255,255,0.1); transition: text-shadow 0.3s ease; }
/* Section desc: fast rise with slight delay */
.section-desc   { animation: hdrUp 0.25s ease 0.09s both; }
/* Accent-line: grow left-to-right + moving gradient + pulse glow */
.accent-line {
  background-size: 200% 100%;
  background-image: linear-gradient(90deg, var(--blue), var(--blue-lighter), var(--blue));
  animation: lineGrow 0.28s ease 0.07s both, accentShimmer 2.5s linear 0.5s infinite, accentPulse 3s ease 0.5s infinite;
}

/* ── ENHANCED CARD HOVER GLOWS ── */
.service-card { transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease !important; }
.service-card:hover {
  transform: translateY(-7px) !important;
