}
.section-title:hover::before { width: 100%; }

/* ABOUT: Float card + feature hover */
@keyframes floatCard { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
#about .about-right { animation: floatCard 5s ease-in-out infinite; }
#about .about-feature {
  border-left: 2px solid transparent; padding-left: 10px;
  transition: border-color 0.3s ease, padding-left 0.3s ease;
}
#about .about-feature:hover { border-left-color: var(--blue-light); padding-left: 14px; }
#about .about-feature:hover .feature-icon {
  transform: rotate(15deg) scale(1.15);
