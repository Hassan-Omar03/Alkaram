/* CEO: Float frame */
@keyframes floatFrame { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
#ceo .ceo-frame {
  animation: floatFrame 6s ease-in-out infinite;
  border: 1px solid rgba(61,126,199,0.3) !important;
