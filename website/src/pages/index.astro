#blocks .block-card:nth-child(3) { transition-delay: 0.08s; }
#blocks .block-card:nth-child(4) { transition-delay: 0.12s; }
#blocks .block-card:nth-child(5) { transition-delay: 0.16s; }
#blocks .block-card:nth-child(6) { transition-delay: 0.20s; }
#blocks .block-card:nth-child(7) { transition-delay: 0.24s; }
#blocks .block-card:nth-child(8) { transition-delay: 0.28s; }
.block-name { transition: color 0.2s ease; }
.block-card:hover .block-name { color: var(--blue-lighter); }

/* PAYMENT: Shimmer border + feature hover */
@keyframes borderSpin { 0% { background-position: 0% 50%; } 100% { background-position: 200% 50%; } }
#payment .payment-card { position: relative; }
#payment .payment-card::before {
  content: ''; position: absolute; inset: -1px; border-radius: inherit;
  background: linear-gradient(90deg, var(--blue-dark), var(--blue-light), var(--gold), var(--blue-dark));
  background-size: 200% 100%; animation: borderSpin 3s linear infinite;
  z-index: -1; opacity: 0.35;
}
#payment .payment-features li { transition: transform 0.2s ease, color 0.2s ease; cursor: default; }
#payment .payment-features li:hover { transform: translateX(6px); color: var(--white-soft); }

/* TESTIMONIALS: Top border + star twinkle */
.testimonial-card { position: relative; overflow: hidden; }
.testimonial-card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.5), transparent);
  opacity: 0; transition: opacity 0.3s ease;
}
.testimonial-card:hover::after { opacity: 1; }
@keyframes starTwinkle {
  0%,100% { filter: drop-shadow(0 0 3px rgba(212,168,67,0.4)); }
  50%     { filter: drop-shadow(0 0 8px rgba(212,168,67,0.8)); }
}
.testimonial-stars { animation: starTwinkle 2s ease-in-out infinite; }

/* CONTACT: Input focus glow + icon hover */
.contact-form-wrap input:focus,
.contact-form-wrap textarea:focus,
.contact-form-wrap select:focus {
  outline: none;
  border-color: var(--blue-light) !important;
  box-shadow: 0 0 0 3px rgba(61,126,199,0.15) !important;
  background: rgba(61,126,199,0.04) !important;
  transition: all 0.2s ease;
}
.contact-icon { transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease; }
.contact-item:hover .contact-icon { transform: scale(1.15) rotate(-5deg); box-shadow: 0 0 16px rgba(61,126,199,0.3); }

/* WHATSAPP: opacity-only pulse (no box-shadow repaint) */
@keyframes waPulse {
  0%,100% { opacity: 1; }
  50%     { opacity: 0.72; }
}
.whatsapp-float { animation: waPulse 2s ease-in-out infinite !important; }

/* =================================================================
   PERFORMANCE: Strip expensive animations, use GPU-only replacements
   ================================================================= */

/* Accent-line: remove background-position shimmer + box-shadow pulse */
.accent-line {
  background-image: linear-gradient(90deg, var(--blue), var(--blue-lighter)) !important;
  background-size: 100% 100% !important;
  animation: lineGrow 0.28s ease 0.07s both !important;
}

/* section-label: use opacity pulse instead of color/text-shadow */
@keyframes labelPulse { 0%,100% { opacity: 0.85; } 50% { opacity: 1; } }
.section-label { animation: hdrDown 0.22s ease both, labelPulse 3s ease 0.8s infinite !important; }

/* btn-tour + tour-cta: remove box-shadow animation */
.btn-tour { animation: none !important; }
#tour-cta { animation: none !important; }

/* payment border: stop background-position animation */
#payment .payment-card::before { animation: none !important; opacity: 0.28; }

/* will-change for floating elements → GPU layer pre-promotion */
#about .about-right { will-change: transform; }
#ceo .ceo-frame     { will-change: transform; }

/* =================================================================
   SIZE TAGS: Fix readability — bright, high-contrast
   ================================================================= */
.size-tag {
  background: rgba(61,126,199,0.12) !important;
  border: 1px solid rgba(61,126,199,0.3) !important;
}
.size-val {
  color: #ffffff !important;
  font-family: var(--font-body) !important;
