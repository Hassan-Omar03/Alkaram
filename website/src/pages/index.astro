<style>
/* ===== NAVBAR ===== */
#navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: 0 5%;
  transition: all 0.4s;
  background: transparent;
}
#navbar.scrolled {
  background: rgba(7,14,26,0.95);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(61,126,199,0.1);
}
.nav-inner {
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80px;
}
.nav-logo-img {
  height: 52px;
  width: auto;
  object-fit: contain;
  background: white;
  border-radius: 6px;
  padding: 4px 8px;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s;
}
.nav-logo-img:hover {
  transform: scale(1.05);
  box-shadow: 0 4px 20px rgba(61,126,199,0.2);
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 30px;
}
.nav-links a {
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  transition: color var(--transition-fast), transform var(--transition-fast);
  position: relative;
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 1.5px;
  background: var(--white);
  transition: width var(--transition-fast);
}
.nav-links a:hover { color: var(--white); }
.nav-links a:hover::after { width: 100%; }
.nav-links a.nav-active {
  color: var(--white);
}
.nav-links a.nav-active::after {
  width: 100%;
  background: linear-gradient(90deg, var(--blue-light), var(--gold));
  height: 2px;
  box-shadow: 0 0 8px rgba(90,157,224,0.6);
}
/* Nav click flash */
@keyframes navFlash {
  0%   { background: rgba(90,157,224,0.0); }
  30%  { background: rgba(90,157,224,0.18); }
  100% { background: rgba(90,157,224,0.0); }
}
.nav-links a.nav-click-flash {
  animation: navFlash 0.55s ease-out;
  border-radius: 4px;
}
/* Active indicator pill that slides between links */
#nav-pill {
  position: absolute;
  height: 2px;
  bottom: -4px;
  background: linear-gradient(90deg, var(--blue-light), var(--gold-light));
  border-radius: 2px;
  box-shadow: 0 0 10px rgba(90,157,224,0.7);
  transition: left 0.4s cubic-bezier(0.25,0.46,0.45,0.94), width 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
  pointer-events: none;
}
.nav-links { position: relative; }
.nav-tour-btn::after { display: none !important; }
.nav-tour-btn.btn { padding: 10px 24px; font-size: 0.75rem; }
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 5px;
}
.hamburger span {
  width: 25px;
  height: 2px;
  background: var(--blue-light);
  transition: all 0.3s;
}

.cursor-aurora {
  position: fixed;
  top: 0;
  left: 0;
  width: 280px;
  height: 280px;
  pointer-events: none;
  z-index: 30;
  border-radius: 50%;
  opacity: 0;
  transform: translate3d(-50%, -50%, 0) scale(0.9);
  background:
    radial-gradient(circle at 35% 35%, rgba(255,255,255,0.28), rgba(255,255,255,0) 45%),
    radial-gradient(circle at 60% 60%, rgba(90,157,224,0.4), rgba(90,157,224,0) 70%);
  filter: blur(18px);
  mix-blend-mode: screen;
  transition: opacity 0.45s ease, transform 0.35s ease;
}

body.aurora-active .cursor-aurora {
  opacity: 0.62;
}

/* ===== HERO ===== */
#hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
#hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, rgba(7,14,26,0.82) 0%, rgba(7,14,26,0.42) 40%, rgba(7,14,26,0.72) 100%);
  z-index: 1;
}
.hero-particles-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: radial-gradient(ellipse at 30% 50%, rgba(61,126,199,0.06) 0%, transparent 60%),
              radial-gradient(ellipse at 70% 30%, rgba(90,157,224,0.04) 0%, transparent 50%);
}
.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 100px 5% 0;
  max-width: 900px;
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 3px;
  color: rgba(255,255,255,0.85);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 10px 24px;
  margin-bottom: 36px;
  text-transform: uppercase;
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(8px);
  border-radius: 50px;
}
.badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--blue-light);
  animation: dotPulse 2s ease-in-out infinite;
}
@keyframes dotPulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(90,157,224,0.4); }
  50% { opacity: 0.6; box-shadow: 0 0 0 6px rgba(90,157,224,0); }
}
.hero-title {
  font-family: var(--font-heading);
  font-size: clamp(2.8rem, 6.5vw, 5.8rem);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 24px;
  text-shadow: 0 0 80px rgba(90,157,224,0.3);
}
.hero-line { display: block; }
.hero-line .char {
  display: inline-block;
  transform: translateY(120%) rotate(4deg);
  opacity: 0;
  filter: blur(8px);
  transition: transform 0.9s var(--ease-premium), opacity 0.8s ease, filter 0.8s ease;
  transition-delay: var(--char-delay, 0ms);
}
.hero-line .char.space {
  width: 0.26em;
}
.hero-line.animate-in .char {
  transform: translateY(0) rotate(0);
  opacity: 1;
  filter: blur(0);
}
.hero-line.accent {
  background: linear-gradient(90deg, var(--blue-light), var(--blue-lighter), rgba(255,255,255,0.9));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-desc {
  font-size: 1.1rem;
  color: var(--gray-light);
  max-width: 600px;
  margin: 0 auto 40px;
  line-height: 1.8;
}
.hero-btns {
  display: flex;
  gap: 20px;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 60px;
}
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40px;
  flex-wrap: wrap;
}
.stat { text-align: center; }
.glass-stat {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 16px;
  padding: 20px 32px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 4px 24px rgba(0,0,0,0.3);
  position: relative;
}
.glass-stat::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 16px;
  background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.03) 50%, transparent 100%);
  pointer-events: none;
}
.stat-num {
  font-family: var(--font-heading);
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--white);
}
.stat-plus {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  color: rgba(255,255,255,0.6);
}
.stat-label {
  display: block;
  font-size: 0.75rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gray);
  margin-top: 4px;
}
.stat-divider {
  width: 1px;
  height: 50px;
  background: rgba(61,126,199,0.2);
}
.scroll-indicator {
  position: absolute;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.scroll-indicator span {
  font-size: 0.65rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gray);
}
.scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--blue-light), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}
@keyframes scrollPulse {
  0%, 100% { opacity: 1; transform: scaleY(1); }
  50% { opacity: 0.3; transform: scaleY(0.5); }
}


/* ===== ABOUT ===== */
#about {
  background: linear-gradient(180deg, var(--navy-2) 0%, var(--navy-3) 100%);
  position: relative;
  overflow: hidden;
}
#about::before {
  content: '';
  position: absolute;
  top: -200px;
  right: -200px;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(61,126,199,0.09) 0%, transparent 70%);
  pointer-events: none;
}
#about::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.25), transparent);
}
.about-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 80px;
  align-items: center;
}
.about-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 32px;
}
.about-feature {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 0.9rem;
  font-weight: 500;
}
.about-right { display: flex; justify-content: center; }
.about-card {
  width: 320px;
  position: relative;
}
.about-card-inner {
  width: 100%;
  background: linear-gradient(145deg, var(--navy-3), var(--navy-4));
  border: 1px solid rgba(255,255,255,0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 44px 40px;
  text-align: center;
  transition: all var(--transition-slow);
  position: relative;
  z-index: 1;
  border-radius: 18px;
}
.about-card-inner:hover {
  transform: translateY(-12px) scale(1.02);
  box-shadow: 0 35px 70px rgba(0,0,0,0.35), 0 0 60px rgba(61,126,199,0.08);
  border-color: rgba(255,255,255,0.12);
}
.about-logo-img {
  width: 180px;
  height: auto;
  margin-bottom: 20px;
  border-radius: 8px;
  transition: transform var(--transition-medium);
}
.about-card-inner:hover .about-logo-img {
  transform: scale(1.05);
}
.about-card-glow {
  position: absolute;
  inset: -1px;
  background: linear-gradient(135deg, rgba(61,126,199,0.2), transparent, rgba(90,157,224,0.1));
  z-index: 0;
  filter: blur(20px);
  opacity: 0;
  transition: opacity 0.6s;
}
.about-card:hover .about-card-glow { opacity: 1; }
.card-divider {
  width: 40px;
  height: 2px;
  background: linear-gradient(90deg, var(--blue), var(--blue-light));
  margin: 20px 0;
}
.card-parent-label {
  display: block;
  font-size: 0.65rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 4px;
}
.card-parent-name {
  font-size: 1rem;
  font-weight: 600;
  color: var(--blue-light);
}

/* ===== CEO ===== */
#ceo {
  background: var(--navy);
  position: relative;
  overflow: hidden;
}
#ceo::before {
  content: '';
  position: absolute;
  bottom: -100px;
  left: -100px;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(61,126,199,0.04) 0%, transparent 70%);
  pointer-events: none;
}
.ceo-grid {
  display: grid;
  grid-template-columns: 0.7fr 1.3fr;
  gap: 80px;
  align-items: center;
}
.ceo-visual { display: flex; justify-content: center; }
.ceo-frame {
  width: 260px;
  height: 320px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, var(--navy-3), var(--navy-4));
}
.ceo-frame-border {
  position: absolute;
  inset: -2px;
  border: 2px solid transparent;
  background: linear-gradient(135deg, var(--blue), var(--blue-dark), var(--blue-light)) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}
.ceo-initials {
  font-family: var(--font-heading);
  font-size: 4rem;
  font-weight: 700;
  background: linear-gradient(135deg, var(--blue-light), var(--blue-lighter));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  opacity: 0.85;
  position: relative;
  z-index: 2;
  animation: ceoInitialsPulse 3s ease-in-out infinite;
}
@keyframes ceoInitialsPulse {
  0%, 100% { text-shadow: 0 0 30px rgba(90,157,224,0.3); }
  50% { text-shadow: 0 0 60px rgba(90,157,224,0.7), 0 0 100px rgba(90,157,224,0.3); }
}
/* CEO orb particles */
.ceo-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(40px);
  pointer-events: none;
  z-index: 0;
}
.ceo-orb-1 {
  width: 160px; height: 160px;
  background: rgba(61,126,199,0.25);
  top: -40px; left: -40px;
  animation: orbDrift 7s ease-in-out infinite;
}
.ceo-orb-2 {
  width: 120px; height: 120px;
  background: rgba(90,157,224,0.18);
  bottom: -30px; right: -30px;
  animation: orbDrift 9s ease-in-out infinite 2s reverse;
}
.ceo-orb-3 {
  width: 80px; height: 80px;
  background: rgba(212,168,67,0.12);
  top: 50%; right: -20px;
  animation: orbDrift 6s ease-in-out infinite 4s;
}
@keyframes orbDrift {
  0%, 100% { transform: translate(0,0) scale(1); }
  33% { transform: translate(12px,-18px) scale(1.1); }
  66% { transform: translate(-10px, 12px) scale(0.92); }
}
/* CEO spotlight sweep */
.ceo-spotlight {
  position: absolute;
  inset: 0;
  background: conic-gradient(from 0deg at 50% 50%, transparent 0deg, rgba(90,157,224,0.08) 30deg, transparent 60deg);
  animation: spotlightRotate 8s linear infinite;
  pointer-events: none;
  z-index: 1;
  border-radius: inherit;
}
@keyframes spotlightRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
/* CEO badge */
.ceo-badge-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  justify-content: center;
  margin-top: 16px;
  background: rgba(61,126,199,0.08);
  border: 1px solid rgba(61,126,199,0.2);
  border-radius: 50px;
  padding: 8px 20px;
  width: fit-content;
  margin-inline: auto;
}
.ceo-live-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #27ae60;
  animation: livePulse 1.5s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes livePulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(39,174,96,0.5); }
  50% { box-shadow: 0 0 0 6px rgba(39,174,96,0); }
}
.ceo-live-text {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--blue-lighter);
}
.ceo-role {
  font-size: 1rem;
  font-weight: 600;
  color: var(--blue-light);
  margin-bottom: 16px;
  letter-spacing: 0.5px;
}
.ceo-values {
  display: flex;
  flex-direction: column;
  gap: 24px;
  margin-top: 36px;
}
.ceo-value {
  display: flex;
  gap: 16px;
  align-items: flex-start;
}
.value-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  flex-shrink: 0;
  transition: all var(--transition-fast);
  border-radius: 14px;
}
.ceo-value:hover .value-icon {
  background: rgba(61,126,199,0.12);
  border-color: rgba(61,126,199,0.3);
  transform: scale(1.1) rotate(-5deg);
}
.ceo-value {
  transition: transform var(--transition-fast);
}
.ceo-value:hover {
  transform: translateX(6px);
}
.ceo-value h4 {
  font-size: 0.95rem;
  font-weight: 600;
  margin-bottom: 2px;
}
.ceo-value p {
  font-size: 0.85rem;
  color: var(--gray);
  line-height: 1.5;
}

/* ===== SERVICES ===== */
#services {
  background: var(--navy-2);
  position: relative;
  overflow: hidden;
}
.services-header { margin-bottom: 60px; }
.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}
.service-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.16);
  padding: 40px 28px;
  transition: border-color var(--transition-medium), box-shadow var(--transition-medium);
  position: relative;
  overflow: hidden;
  border-radius: 18px;
  backdrop-filter: blur(18px) saturate(1.5);
  -webkit-backdrop-filter: blur(18px) saturate(1.5);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.1), 0 8px 32px rgba(0,0,0,0.28);
  animation: floatCard 4s ease-in-out infinite;
}
.service-card:nth-child(1) { animation-delay: 0s; }
.service-card:nth-child(2) { animation-delay: 0.8s; }
.service-card:nth-child(3) { animation-delay: 1.6s; }
.service-card:nth-child(4) { animation-delay: 2.4s; }
@keyframes floatCard {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
}
.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--blue), var(--blue-light), var(--white));
  transform: scaleX(0);
  transition: transform 0.5s var(--ease-premium);
  transform-origin: left;
}
.service-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at top center, rgba(255,255,255,0.03) 0%, transparent 60%);
  opacity: 0;
  transition: opacity var(--transition-medium);
}
.service-card:hover::before { transform: scaleX(1); }
.service-card:hover::after { opacity: 1; }
.service-card:hover {
  transform: translateY(-10px);
  border-color: rgba(255,255,255,0.12);
  box-shadow: 0 25px 50px rgba(0,0,0,0.4), 0 0 40px rgba(61,126,199,0.08);
}
.service-card .service-icon {
  transition: transform var(--transition-medium);
}
.service-card:hover .service-icon {
  transform: scale(1.15) translateY(-4px);
}
.service-num {
  font-family: var(--font-heading);
  font-size: 3rem;
  font-weight: 700;
  color: rgba(61,126,199,0.06);
  position: absolute;
  top: 15px;
  right: 20px;
}
.service-icon { margin-bottom: 24px; }
.service-card h3 {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  margin-bottom: 12px;
}
.service-card p {
  font-size: 0.88rem;
  color: var(--gray-light);
  line-height: 1.7;
}
.service-link {
  display: inline-block;
  margin-top: 16px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--blue-light);
  transition: all 0.3s;
}
.service-link:hover { letter-spacing: 1px; }
.service-line {
  position: absolute;
  bottom: 0;
  left: 28px;
  right: 28px;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.12), transparent);
}

/* ===== TOUR CTA ===== */
#tour-cta {
  padding: 0;
  position: relative;
}
#tour-cta::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(212,168,67,0.35), transparent);
  z-index: 2;
}
#tour-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.tour-cta-inner {
  position: relative;
  padding: 120px 5%;
  text-align: center;
  overflow: hidden;
}
.tour-cta-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--navy-3) 0%, rgba(61,126,199,0.08) 50%, var(--navy-3) 100%);
  border-top: 1px solid rgba(61,126,199,0.1);
  border-bottom: 1px solid rgba(61,126,199,0.1);
}
.tour-orbs {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
}
.orb-1 { width: 300px; height: 300px; background: rgba(61,126,199,0.06); top: -100px; left: 10%; animation: orbFloat 8s ease-in-out infinite; }
.orb-2 { width: 200px; height: 200px; background: rgba(90,157,224,0.05); bottom: -50px; right: 15%; animation: orbFloat 10s ease-in-out infinite 2s; }
.orb-3 { width: 150px; height: 150px; background: rgba(61,126,199,0.04); top: 30%; right: 30%; animation: orbFloat 7s ease-in-out infinite 4s; }
@keyframes orbFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20px) scale(1.1); }
}
.tour-cta-content { position: relative; z-index: 1; }

/* ===== PROJECTS ===== */
#projects {
  background: var(--navy);
  position: relative;
}
.project-showcase {
  display: grid;
  grid-template-columns: 1.3fr 0.7fr;
  gap: 40px;
  margin-top: 40px;
}
.project-main {
  background: linear-gradient(145deg, var(--navy-3), var(--navy-4));
  border: 1px solid rgba(255,255,255,0.06);
  padding: 48px;
  position: relative;
  overflow: hidden;
  transition: all var(--transition-medium);
  border-radius: 18px;
}
.project-main:hover {
  border-color: rgba(255,255,255,0.1);
  box-shadow: 0 20px 50px rgba(0,0,0,0.3);
}
.project-badge {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--white);
  background: linear-gradient(135deg, var(--blue), var(--blue-dark));
  padding: 6px 16px;
  margin-bottom: 20px;
  border-radius: 6px;
}
.project-location {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9rem;
  color: var(--blue-light);
  margin-bottom: 16px;
}
.project-desc {
  font-size: 0.92rem;
  color: var(--gray-light);
  line-height: 1.8;
  margin-bottom: 24px;
}
.project-plots {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10px;
  margin-bottom: 30px;
}
.plot-card {
  position: relative;
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  display: block;
  height: 200px;
  border: 1px solid rgba(61,126,199,0.15);
  transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.35s, border-color 0.3s;
}
.plot-card:hover {
  transform: translateY(-10px) scale(1.05);
  border-color: var(--blue-light);
  box-shadow: 0 24px 48px rgba(0,0,0,0.55), 0 0 30px rgba(61,126,199,0.25);
}
.plot-card-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  transition: transform 0.6s ease;
}
.plot-card:hover .plot-card-img { transform: scale(1.12); }
.plot-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(7,14,26,0.96) 0%, rgba(7,14,26,0.5) 45%, rgba(7,14,26,0.1) 100%);
  transition: background 0.3s;
}
.plot-card:hover .plot-card-overlay {
  background: linear-gradient(to top, rgba(7,14,26,0.97) 0%, rgba(61,126,199,0.25) 50%, rgba(7,14,26,0.1) 100%);
}
/* top badge */
.plot-card-badge {
  display: inline-block;
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #ff6b35;
  background: rgba(255,107,53,0.2);
  border: 1px solid rgba(255,107,53,0.6);
  padding: 3px 8px;
  border-radius: 20px;
  align-self: flex-start;
}
.plot-card-main {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.plot-card-body {
  position: absolute;
  inset: 0;
  padding: 10px 12px 12px;
  text-align: center;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
}
.plot-card-num {
  display: block;
  font-family: var(--font-heading);
  font-size: 3rem;
  font-weight: 700;
  line-height: 1;
  background: linear-gradient(135deg, var(--white), var(--blue-lighter));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  transition: transform 0.3s;
}
.plot-card:hover .plot-card-num { transform: scale(1.08); }
.plot-card-unit {
  display: block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.8);
  margin-top: 2px;
}
.plot-card-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--blue-light);
  margin-top: 10px;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.3s, transform 0.3s;
  border-top: 1px solid rgba(61,126,199,0.25);
  padding-top: 8px;
}
.plot-card:hover .plot-card-cta { opacity: 1; transform: translateY(0); }
/* Amenities header upgrade */
.amenities-header {
  text-align: center;
  margin-bottom: 20px;
}
.amenities-label {
  display: block;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--blue-light);
  margin-bottom: 6px;
}
.amenities-header h3 {
  font-family: var(--font-heading);
  font-size: 1.15rem;
  font-weight: 700;
  background: linear-gradient(135deg, var(--white), var(--blue-lighter));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 0 0 10px;
}
.amenities-accent {
  width: 36px;
  height: 2px;
  background: linear-gradient(90deg, var(--blue), var(--blue-light));
  margin: 0 auto;
  border-radius: 2px;
}
.project-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.project-actions .btn { padding: 14px 28px; font-size: 0.78rem; }
.project-amenities {
  background: linear-gradient(145deg, var(--navy-3), var(--navy-4));
  border: 1px solid rgba(255,255,255,0.06);
  padding: 36px;
  transition: border-color var(--transition-medium);
  border-radius: 18px;
}
.project-amenities:hover {
  border-color: rgba(255,255,255,0.1);
}
.project-amenities h3 {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  margin-bottom: 24px;
  text-align: center;
}
.amenities-grid-mini {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
}
.amenity-mini {
  background: rgba(17,30,52,0.5);
  border: 1px solid rgba(90,157,224,0.12);
  padding: 18px 10px 14px;
  text-align: center;
  transition: all var(--transition-fast);
  border-radius: 12px;
  backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.amenity-mini:hover {
  border-color: rgba(90,157,224,0.35);
  transform: translateY(-6px) scale(1.05);
  background: rgba(61,126,199,0.1);
  box-shadow: 0 12px 28px rgba(0,0,0,0.25), 0 0 20px rgba(61,126,199,0.1);
}
.ami {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  background: rgba(61,126,199,0.1);
  border-radius: 12px;
  border: 1px solid rgba(90,157,224,0.15);
  margin: 0 auto;
  transition: all var(--transition-fast);
}
.amenity-mini:hover .ami {
  background: rgba(61,126,199,0.2);
  box-shadow: 0 0 16px rgba(90,157,224,0.25);
  transform: scale(1.08);
}
.amenity-mini span:last-child {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.5px;
  color: var(--gray-light);
}

/* ===== BLOCKS ===== */
#blocks {
  background: linear-gradient(180deg, var(--navy-2) 0%, var(--navy-3) 100%);
  position: relative;
}
#blocks::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.2), transparent);
}
.blocks-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 40px;
  margin-bottom: 50px;
}
.blocks-header .section-desc { text-align: right; margin-bottom: 0; }
.blocks-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 50px;
}
.block-card {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 30px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
  transition: border-color var(--transition-medium), box-shadow var(--transition-medium);
  position: relative;
  border-radius: 16px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 4px 24px rgba(0,0,0,0.25);
  animation: floatBlock 4.5s ease-in-out infinite;
}
.block-card:nth-child(1) { animation-delay: 0s; }
.block-card:nth-child(2) { animation-delay: 0.6s; }
.block-card:nth-child(3) { animation-delay: 1.2s; }
.block-card:nth-child(4) { animation-delay: 1.8s; }
.block-card:nth-child(5) { animation-delay: 2.4s; }
.block-card:nth-child(6) { animation-delay: 3.0s; }
.block-card:nth-child(7) { animation-delay: 3.6s; }
.block-card:nth-child(8) { animation-delay: 4.2s; }
@keyframes floatBlock {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
}
.block-glow {
  position: absolute;
  top: -20px;
  left: 50%;
  transform: translateX(-50%);
  width: 100px;
  height: 100px;
  background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%);
  opacity: 0;
  transition: opacity var(--transition-medium);
}
.block-card:hover .block-glow { opacity: 1; }
.block-card:hover {
  border-color: rgba(255,255,255,0.15);
  transform: translateY(-8px) scale(1.02);
  box-shadow: 0 25px 50px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.05);
}
.block-card:hover .block-name {
  color: var(--white);
}
.block-card.featured {
  background: rgba(61,126,199,0.15);
  border-color: rgba(61,126,199,0.4);
  box-shadow: inset 0 1px 0 rgba(90,157,224,0.2), 0 4px 24px rgba(61,126,199,0.15);
}
.block-name {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  font-weight: 600;
}
.block-status {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
}
.block-status.available { color: #27ae60; }
.blocks-sizes {
  text-align: center;
  padding-top: 40px;
  border-top: 1px solid rgba(61,126,199,0.08);
}
.blocks-sizes h3 {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  margin-bottom: 24px;
}
.size-tags {
  display: flex;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
}
.size-tag {
  background: linear-gradient(145deg, var(--navy-3), var(--navy-4));
  border: 1px solid rgba(61,126,199,0.12);
  padding: 24px 40px;
  text-align: center;
  transition: all 0.3s;
  border-radius: 14px;
}
.size-tag:hover { border-color: var(--blue); transform: translateY(-4px); }
.size-val {
  display: block;
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  background: linear-gradient(135deg, var(--blue-light), var(--blue-lighter));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.size-unit {
  font-size: 0.75rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--gray);
}

/* ===== ADVANCED SECTION ANIMATIONS ===== */

/* Services: 3D perspective context */
#services .services-grid { perspective: 1400px; }

/* Service icon orbital ring */
.service-icon {
  position: relative;
  width: 72px;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  background: rgba(61,126,199,0.08);
  border-radius: 18px;
  border: 1px solid rgba(90,157,224,0.15);
}
.service-icon::after {
  content: '';
  position: absolute;
  inset: -6px;
  border-radius: 24px;
  border: 1.5px solid transparent;
  border-top-color: rgba(90,157,224,0.7);
  border-right-color: rgba(90,157,224,0.25);
  animation: iconOrbit 2.5s linear infinite;
}
.service-card:nth-child(2) .service-icon::after { animation-duration: 3.2s; }
.service-card:nth-child(3) .service-icon::after { animation-duration: 2.8s; animation-direction: reverse; }
.service-card:nth-child(4) .service-icon::after { animation-duration: 3.6s; }
@keyframes iconOrbit { to { transform: rotate(360deg); } }
.service-card { transform-style: preserve-3d; will-change: transform; }

/* Payment holographic spinning border */
@property --border-angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}
.payment-card.highlight {
  --border-angle: 0deg;
  background:
    linear-gradient(145deg, var(--navy-3), var(--navy-4)) padding-box,
    conic-gradient(
      from var(--border-angle),
      rgba(61,126,199,0.9) 0%,
      rgba(90,157,224,1) 20%,
      rgba(212,168,67,0.85) 40%,
      rgba(255,255,255,0.5) 55%,
      rgba(61,126,199,0.9) 70%,
      rgba(90,157,224,1) 85%,
      rgba(61,126,199,0.9) 100%
    ) border-box;
  border: 2px solid transparent !important;
  animation: spinBorder 4s linear infinite, floatCard 4s ease-in-out infinite;
  box-shadow: 0 0 40px rgba(61,126,199,0.15), 0 0 80px rgba(61,126,199,0.06), 0 20px 60px rgba(0,0,0,0.4);
}
@keyframes spinBorder { to { --border-angle: 360deg; } }

/* Payment shimmer sweep */
.payment-card-shine {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    transparent 20%,
    rgba(255,255,255,0.04) 38%,
    rgba(255,255,255,0.10) 50%,
    rgba(255,255,255,0.04) 62%,
    transparent 80%
  );
  background-size: 200% 100%;
  animation: payShimmer 3s ease-in-out infinite;
  pointer-events: none;
  z-index: 1;
  border-radius: inherit;
}
@keyframes payShimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* Payment feature items — start hidden, JS reveals */
.payment-features li {
  opacity: 0;
  transform: translateX(-28px);
  transition: opacity 0.45s ease, transform 0.45s cubic-bezier(0.34,1.56,0.64,1);
}
.payment-features li.pay-visible {
  opacity: 1;
  transform: translateX(0);
}

/* Project section 3D */
.project-showcase { perspective: 1200px; }
.project-main { transform-style: preserve-3d; }

/* LDA badge glow pulse */
.project-badge {
  animation: ldaGlow 2s ease-in-out infinite;
}
@keyframes ldaGlow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(61,126,199,0.5), 0 0 10px rgba(61,126,199,0.2); }
  50% { box-shadow: 0 0 0 8px rgba(61,126,199,0), 0 0 20px rgba(61,126,199,0.4); }
}

/* Plot tags start hidden */
.plot-tag {
  transform: scale(0) translateY(10px);
  opacity: 0;
  transition: transform 0.5s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s ease;
  display: inline-block;
}
.plot-tag.pt-visible {
  transform: scale(1) translateY(0);
  opacity: 1;
}

/* ===== PAYMENT ===== */
#payment {
  background: var(--navy);
  position: relative;
  overflow: hidden;
}
.payment-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}
.payment-card-wrap { display: flex; justify-content: center; }
.payment-card {
  background: linear-gradient(145deg, var(--navy-3), var(--navy-4));
  border: 1px solid rgba(255,255,255,0.06);
  padding: 44px;
  transition: all var(--transition-medium);
  width: 100%;
  max-width: 480px;
  position: relative;
  overflow: hidden;
  border-radius: 20px;
}
.payment-card.highlight { border-color: rgba(61,126,199,0.3); }
.payment-card-shine {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--blue), var(--blue-light), var(--blue));
}
.payment-card:hover {
  transform: translateY(-10px) scale(1.01);
  box-shadow: 0 35px 70px rgba(0,0,0,0.35), 0 0 50px rgba(61,126,199,0.06);
  border-color: rgba(255,255,255,0.12);
}
.payment-card-header { margin-bottom: 28px; }
.payment-tag {
  display: inline-block;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--white);
  background: linear-gradient(135deg, var(--blue), var(--blue-dark));
  padding: 5px 14px;
  margin-bottom: 14px;
  border-radius: 6px;
}
.payment-card h3 {
  font-family: var(--font-heading);
  font-size: 1.8rem;
}
.payment-sub {
  font-size: 0.85rem;
  color: var(--gray);
  margin-top: 4px;
}
.payment-features {
  list-style: none;
  margin-bottom: 32px;
}
.payment-features li {
  display: flex;
  align-items: center;
  gap: 14px;
  font-size: 0.92rem;
  padding: 12px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

/* ===== CONTACT ===== */
#contact {
  background: linear-gradient(180deg, var(--navy-2) 0%, var(--navy) 100%);
  position: relative;
}
#contact::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(212,168,67,0.2), rgba(61,126,199,0.3), transparent);
}
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
}
.contact-details { margin-top: 40px; }
.contact-item {
  display: flex;
  gap: 16px;
  margin-bottom: 28px;
}
.contact-icon {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  flex-shrink: 0;
  transition: all var(--transition-fast);
  border-radius: 14px;
}
.contact-item:hover .contact-icon {
  background: rgba(61,126,199,0.12);
  border-color: rgba(61,126,199,0.3);
  transform: scale(1.1);
}
.contact-item h4 {
  font-size: 0.85rem;
  font-weight: 600;
  margin-bottom: 4px;
}
.contact-item p {
  font-size: 0.9rem;
  color: var(--gray-light);
  line-height: 1.6;
}
.contact-item a { color: rgba(255,255,255,0.8); transition: all var(--transition-fast); }
.contact-item a:hover { color: var(--white); text-shadow: 0 0 8px rgba(255,255,255,0.15); }
.contact-social {
  display: flex;
  gap: 16px;
  margin-top: 30px;
}
.social-link {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.7);
  transition: all var(--transition-fast);
  border-radius: 12px;
}
.social-link:hover {
  background: rgba(255,255,255,0.1);
  color: var(--white);
  border-color: rgba(255,255,255,0.3);
  transform: translateY(-3px) scale(1.1);
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}
.contact-form-wrap {
  background: linear-gradient(145deg, var(--navy-3), var(--navy-4));
  border: 1px solid rgba(255,255,255,0.06);
  padding: 48px;
  transition: border-color var(--transition-medium);
  border-radius: 20px;
}
.contact-form-wrap:hover {
  border-color: rgba(255,255,255,0.1);
}
.contact-form h3 {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  margin-bottom: 28px;
}
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}
.form-group { margin-bottom: 18px; }
.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 14px 18px;
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--white);
  background: var(--navy);
  border: 1px solid rgba(255,255,255,0.08);
  outline: none;
  transition: all var(--transition-fast);
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: rgba(255,255,255,0.3);
  box-shadow: 0 0 0 3px rgba(255,255,255,0.05);
  background: rgba(255,255,255,0.02);
}
.form-group input:hover,
.form-group select:hover,
.form-group textarea:hover {
  border-color: rgba(255,255,255,0.15);
}
.form-group select { cursor: pointer; }
.form-group select option { background: var(--navy-3); }
.form-group textarea { resize: vertical; }

/* ===== FOOTER ===== */
#footer {
  background: var(--navy);
  border-top: 1px solid rgba(61,126,199,0.08);
}
.footer-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 60px 5% 30px;
}
.footer-top {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: 50px;
  margin-bottom: 40px;
}
.footer-logo-img {
  width: 150px;
  height: auto;
  margin-bottom: 16px;
  background: white;
  border-radius: 6px;
  padding: 6px 10px;
}
.footer-brand p {
  font-size: 0.88rem;
  color: var(--gray);
  line-height: 1.7;
}
.footer-links h4 {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.85);
  margin-bottom: 20px;
}
.footer-links a {
  display: block;
  font-size: 0.88rem;
  color: rgba(255,255,255,0.55);
  padding: 5px 0;
  transition: all var(--transition-fast);
}
.footer-links a:hover {
  color: var(--white);
  transform: translateX(4px);
}
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 30px;
  border-top: 1px solid rgba(61,126,199,0.06);
  font-size: 0.8rem;
  color: var(--gray);
}

/* ===== WHATSAPP FLOAT ===== */
.whatsapp-float {
  position: fixed;
  bottom: 30px;
  right: 30px;
  z-index: 999;
  width: 60px;
  height: 60px;
  background: #25D366;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 20px rgba(37,211,102,0.4);
  transition: all 0.3s;
  animation: whatsappPulse 2s infinite;
}
.whatsapp-float:hover {
  transform: scale(1.1);
  box-shadow: 0 8px 30px rgba(37,211,102,0.5);
}
@keyframes whatsappPulse {
  0%, 100% { box-shadow: 0 6px 20px rgba(37,211,102,0.4); }
  50% { box-shadow: 0 6px 30px rgba(37,211,102,0.6), 0 0 0 10px rgba(37,211,102,0.1); }
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .services-grid { grid-template-columns: repeat(2, 1fr); }
  .blocks-grid { grid-template-columns: repeat(4, 1fr); }
  .payment-layout { grid-template-columns: 1fr; }
  .footer-top { grid-template-columns: 1fr 1fr; }
  .project-showcase { grid-template-columns: 1fr; }
  .ceo-grid { grid-template-columns: 1fr; }
  .ceo-visual { order: -1; }
  .blocks-header { flex-direction: column; align-items: flex-start; }
  .blocks-header .section-desc { text-align: left; }
}
@media (max-width: 768px) {
  .nav-links {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(7,14,26,0.98);
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 24px;
    z-index: 999;
  }
  .nav-links.open { display: flex; }
  .nav-links a { font-size: 1.1rem; }
  .hamburger { display: flex; z-index: 1000; }
  .about-grid { grid-template-columns: 1fr; gap: 40px; }
  .about-right { order: -1; }
  .services-grid { grid-template-columns: 1fr; }
  .blocks-grid { grid-template-columns: repeat(2, 1fr); }
  .amenities-grid-mini { grid-template-columns: repeat(3, 1fr); }
  .contact-grid { grid-template-columns: 1fr; }
  .form-row { grid-template-columns: 1fr; }
  .footer-top { grid-template-columns: 1fr; gap: 30px; }
  .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
  .hero-stats { gap: 20px; }
  .stat-divider { display: none; }
  .contact-form-wrap { padding: 30px 20px; }
  /* Hero buttons equal width on mobile */
  .hero-btns { flex-direction: row; gap: 12px; }
  .hero-btns .btn { flex: 1; justify-content: center; text-align: center; font-size: 0.75rem; padding: 14px 10px; }
  /* Stats in one row */
  .hero-stats { flex-wrap: nowrap; gap: 0; justify-content: space-around; width: 100%; }
  .stat-divider { display: block; width: 1px; height: 40px; background: rgba(61,126,199,0.2); }
  .stat-num { font-size: 1.6rem; }
  .stat-plus { font-size: 1rem; }
  .stat-label { font-size: 0.6rem; letter-spacing: 1px; }
  /* Plot cards responsive */
  .project-plots { grid-template-columns: repeat(3, 1fr); }
  .plot-card { height: 140px; }
  .plot-card-num { font-size: 2rem; }
  /* Available badge — use orange/red for visibility */
  .plot-card-badge { color: #ff6b35; background: rgba(255,107,53,0.15); border-color: rgba(255,107,53,0.5); }
  /* Project main padding */
  .project-main { padding: 24px; }
}
@media (max-width: 480px) {
  .amenities-grid-mini { grid-template-columns: repeat(2, 1fr); }
  .blocks-grid { grid-template-columns: repeat(2, 1fr); }
  .hero-btns { flex-direction: row; gap: 10px; }
  .hero-btns .btn { flex: 1; font-size: 0.7rem; padding: 12px 8px; }
  .project-plots { grid-template-columns: repeat(2, 1fr); }
  .plot-card { height: 130px; }
}

.cinematic-section {
  position: relative;
  isolation: isolate;
}
.cinematic-section::before,
.cinematic-section::after {
  content: '';
  position: absolute;
  width: 360px;
  height: 360px;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
  opacity: 0;
  filter: blur(70px);
  transition: opacity 1.2s ease, transform 1.2s var(--ease-premium);
}
.cinematic-section::before {
  top: -180px;
  right: -120px;
  background: radial-gradient(circle, rgba(90,157,224,0.2) 0%, rgba(90,157,224,0) 68%);
  transform: scale(0.7);
}
.cinematic-section::after {
  bottom: -200px;
  left: -120px;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0) 68%);
  transform: scale(0.74);
}
.cinematic-section.in-view::before,
.cinematic-section.in-view::after {
  opacity: 1;
  transform: scale(1);
}

.section > * {
  position: relative;
  z-index: 1;
}

.section-title {
  position: relative;
  display: inline-block;
  overflow: hidden;
}
.section-title::after {
  content: '';
  position: absolute;
  inset: 0;
  transform: translateX(0);
  background: linear-gradient(100deg, rgba(7,14,26,0.96), rgba(7,14,26,0.82));
  transition: transform 1.1s var(--ease-premium);
}
.section-title.visible::after {
  transform: translateX(108%);
}

.btn {
  will-change: transform;
}
.btn.magnetic-active {
  box-shadow: 0 16px 35px rgba(61,126,199,0.25), 0 0 0 1px rgba(255,255,255,0.12);
}

/* ===== REVEAL ANIMATIONS ===== */
.reveal {
  opacity: 0;
  transform: translateY(35px);
  transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeInScale {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}
.tilt-card {
  transform-style: preserve-3d;
  perspective: 1000px;
}
.tilt-card-inner {
  transition: transform 0.15s ease-out;
  transform-style: preserve-3d;
}
.tilt-shine {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at var(--shine-x, 50%) var(--shine-y, 50%), rgba(255,255,255,0.06) 0%, transparent 60%);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s;
  z-index: 2;
}
.tilt-card:hover .tilt-shine { opacity: 1; }

@media (prefers-reduced-motion: reduce) {
  .cursor-aurora,
  .cinematic-section::before,
  .cinematic-section::after,
  .hero-line .char {
    transition: none !important;
    animation: none !important;
  }
  .hero-line .char {
    transform: none;
    opacity: 1;
    filter: none;
  }
}

/* CEO section entrance — start hidden, Motion.dev reveals */
#ceo .ceo-frame,
#ceo .ceo-role,
#ceo .ceo-value,
#ceo .value-icon,
#ceo .ceo-info .section-title {
  opacity: 0;
  transform: translateY(30px);
}

/* Testimonials entrance — start hidden, Motion.dev reveals */
#testimonials .testimonials-header h2,
#testimonials .testimonials-header .section-label,
#testimonials .testimonials-header .accent-line,
#testimonials .testimonial-card {
  opacity: 0;
  transform: translateY(40px);
}

/* Override section-title::after for CEO so it doesn't block */
#ceo .section-title::after { display: none; }
#scroll-progress {
  position: fixed;
  top: 0;
  left: 0;
  height: 2px;
  width: 0%;
  background: linear-gradient(90deg, var(--blue-dark), var(--blue), var(--blue-lighter), var(--gold));
  z-index: 9999;
  transition: width 0.1s linear;
  box-shadow: 0 0 8px rgba(90,157,224,0.6);
}

/* ===== MARQUEE TICKER ===== */
.marquee-strip {
  background: rgba(255,255,255,0.05);
  border-top: 1px solid rgba(255,255,255,0.2);
  border-bottom: 1px solid rgba(255,255,255,0.2);
  overflow: hidden;
  padding: 14px 0;
  position: relative;
  z-index: 5;
  margin-top: 24px;
}
.marquee-strip::before,
.marquee-strip::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 80px;
  z-index: 2;
  pointer-events: none;
}
.marquee-strip::before {
  left: 0;
  background: linear-gradient(90deg, var(--navy-2), transparent);
}
.marquee-strip::after {
  right: 0;
  background: linear-gradient(-90deg, var(--navy-2), transparent);
}
.marquee-track {
  display: flex;
  align-items: center;
  gap: 0;
  white-space: nowrap;
  animation: marqueeScroll 30s linear infinite;
  width: max-content;
}
.marquee-track span {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  padding: 0 24px;
  transition: color 0.3s;
}
.marquee-track span:hover { color: var(--blue-lighter); }
.marquee-dot {
  color: var(--gold) !important;
  font-size: 0.55rem !important;
  padding: 0 !important;
  letter-spacing: 0 !important;
  opacity: 0.7;
}
@keyframes marqueeScroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ===== TESTIMONIALS ===== */
#testimonials {
  background: var(--navy);
  position: relative;
  overflow: hidden;
}
#testimonials::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.4), rgba(212,168,67,0.3), transparent);
}
/* floating bg orbs in testimonials */
#testimonials::after {
  content: '';
  position: absolute;
  width: 500px; height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(61,126,199,0.06) 0%, transparent 70%);
  top: -100px; left: 50%;
  transform: translateX(-50%);
  pointer-events: none;
  animation: testimonialsOrb 8s ease-in-out infinite;
}
@keyframes testimonialsOrb {
  0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.6; }
  50% { transform: translateX(-50%) scale(1.2); opacity: 1; }
}
.testimonials-header {
  text-align: center;
  margin-bottom: 60px;
  position: relative;
  z-index: 1;
}
.testimonials-header h2 {
  background: linear-gradient(135deg, var(--white) 0%, var(--blue-lighter) 50%, var(--white) 100%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmerText 4s linear infinite;
}
@keyframes shimmerText {
  0% { background-position: 0% center; }
  100% { background-position: 200% center; }
}
.testimonials-header .accent-line {
  margin: 24px auto;
}
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  position: relative;
  z-index: 1;
}
.testimonial-card {
  background: rgba(12, 21, 38, 0.45);
  border: 1px solid rgba(90, 157, 224, 0.13);
  padding: 40px 36px;
  position: relative;
  overflow: hidden;
  transition: border-color var(--transition-medium), box-shadow var(--transition-medium), transform var(--transition-medium);
  backdrop-filter: blur(22px) saturate(1.6);
  -webkit-backdrop-filter: blur(22px) saturate(1.6);
  border-radius: 20px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.32), inset 0 1px 0 rgba(255,255,255,0.07);
  animation: floatTestimonial 5s ease-in-out infinite;
}
.testimonial-card:nth-child(1) { animation-delay: 0s; }
.testimonial-card:nth-child(2) { animation-delay: 1s; }
.testimonial-card:nth-child(3) { animation-delay: 2s; }
@keyframes floatTestimonial {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-7px); }
}
/* shimmer sweep on card */
.testimonial-card::after {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
  animation: cardShimmer 6s ease-in-out infinite;
  pointer-events: none;
}
.testimonial-card:nth-child(2)::after { animation-delay: 2s; }
.testimonial-card:nth-child(3)::after { animation-delay: 4s; }
@keyframes cardShimmer {
  0% { left: -100%; }
  50%, 100% { left: 150%; }
}
.testimonial-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--blue-dark), var(--blue-light), var(--gold));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.5s var(--ease-premium);
}
.testimonial-card:hover::before { transform: scaleX(1); }
.testimonial-card:hover {
  border-color: rgba(61,126,199,0.3);
  box-shadow: 0 30px 60px rgba(0,0,0,0.4), 0 0 50px rgba(61,126,199,0.1);
}
.testimonial-quote {
  font-size: 3.5rem;
  line-height: 1;
  color: var(--blue);
  opacity: 0.25;
  margin-bottom: 20px;
  font-family: Georgia, serif;
}
.testimonial-text {
  font-size: 0.95rem;
  color: var(--gray-light);
  line-height: 1.85;
  margin-bottom: 28px;
  font-style: italic;
}
.testimonial-author {
  display: flex;
  align-items: center;
  gap: 14px;
  padding-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.05);
}
.author-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--blue-dark), var(--blue));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  flex-shrink: 0;
  border: 1px solid rgba(90,157,224,0.3);
}
.author-name {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--white-soft);
}
.author-role {
  font-size: 0.75rem;
  color: var(--gray);
  margin-top: 2px;
}
.testimonial-stars {
  margin-left: auto;
  color: var(--gold);
  font-size: 0.9rem;
  letter-spacing: 2px;
  flex-shrink: 0;
  animation: starPop 0.4s ease-out;
  filter: drop-shadow(0 0 4px rgba(212,168,67,0.5));
}
@keyframes starPop {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

/* ===== GLASS MORPHISM — ALL BOXES ===== */
/* Identical to hero badge: rgba(255,255,255,0.05) bg + rgba(255,255,255,0.2) border + backdrop-filter blur(8px) */
.btn-outline,
.about-card-inner,
.service-card,
.block-card,
.size-tag,
.testimonial-card,
.payment-card,
.project-main,
.project-amenities,
.amenity-mini,
.contact-form-wrap,
.contact-icon,
.ceo-frame {
  background: rgba(255,255,255,0.05) !important;
  border: 1px solid rgba(255,255,255,0.15) !important;
  backdrop-filter: blur(3px) !important;
  -webkit-backdrop-filter: blur(3px) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), 0 4px 20px rgba(0,0,0,0.2) !important;
}
.block-card.featured {
  background: rgba(61,126,199,0.08) !important;
  border-color: rgba(61,126,199,0.35) !important;
}

/* ===== SECTION DIVIDERS ===== */
.section-dot-divider {
  display: flex;
  justify-content: center;
  gap: 6px;
  padding: 20px 0;
}
.section-dot-divider span {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: rgba(61,126,199,0.25);
}
.section-dot-divider span:nth-child(2) {
  background: rgba(61,126,199,0.5);
  transform: scale(1.4);
}

/* ===== ENHANCED FEATURE ICON ===== */
.feature-icon {
  width: 38px;
  height: 38px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(61,126,199,0.08);
  border: 1px solid rgba(61,126,199,0.15);
  flex-shrink: 0;
  transition: all var(--transition-fast);
}
.about-feature:hover .feature-icon {
  background: rgba(61,126,199,0.18);
  transform: scale(1.12) rotate(-5deg);
  box-shadow: 0 0 15px rgba(61,126,199,0.2);
}

/* ===== ENHANCED FOOTER ===== */
#footer::before {
  content: '';
  display: block;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.3), rgba(212,168,67,0.2), transparent);
}

/* ===== RESPONSIVE: TESTIMONIALS ===== */
@media (max-width: 1024px) {
  .testimonials-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 768px) {
  .testimonials-grid { grid-template-columns: 1fr; }
  .marquee-track { animation-duration: 20s; }
}

/* ===== CUSTOM MORPHING CURSOR ===== */
#cursor-dot {
  position: fixed;
  top: 0; left: 0;
  width: 8px;
  height: 8px;
  background: var(--blue-light);
  border-radius: 50%;
  pointer-events: none;
  z-index: 99999;
  transform: translate(-50%, -50%);
  transition: width 0.2s ease, height 0.2s ease, background 0.2s ease, border-radius 0.2s ease;
  mix-blend-mode: screen;
}
#cursor-ring {
  position: fixed;
  top: 0; left: 0;
  width: 36px;
  height: 36px;
  border: 1.5px solid rgba(90, 157, 224, 0.55);
  border-radius: 50%;
  pointer-events: none;
  z-index: 99998;
  transform: translate(-50%, -50%);
  transition: width 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
              height 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
              border-color 0.3s ease,
              border-radius 0.3s ease,
              background 0.3s ease;
}
body.cursor-btn #cursor-dot { width: 6px; height: 6px; background: white; }
body.cursor-btn #cursor-ring { width: 56px; height: 56px; border-color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.04); }
body.cursor-card #cursor-dot { width: 10px; height: 10px; background: var(--blue-lighter); }
body.cursor-card #cursor-ring { width: 50px; height: 50px; border-color: rgba(90,157,224,0.5); border-radius: 14px; background: rgba(61,126,199,0.05); }
body.cursor-link #cursor-ring { width: 44px; height: 44px; border-color: var(--gold); background: rgba(212,168,67,0.05); }
@media (max-width: 768px) { #cursor-dot, #cursor-ring { display: none; } }

/* ===================================================================
   TARGETED SECTION HEADER FIXES
   =================================================================== */

/* ── WHO WE ARE ──
   Label: text-align center
   Heading: bigger font
   Accent-line: tighter gap after heading                             */
#about .about-left .section-label {
