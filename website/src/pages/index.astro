  font-weight: 700 !important;
  opacity: 1 !important;
  display: block !important;
  line-height: 1.1 !important;
}
.size-unit {
  color: var(--blue-lighter) !important;
  opacity: 1 !important;
  display: block !important;
  font-size: 0.78rem !important;
  letter-spacing: 2px !important;
}
/* Plot card numbers (3, 5, 10, 15 Marla, 1 Kanal) */
.plot-card-num {
  font-family: var(--font-body) !important;
  font-weight: 800 !important;
}
/* Hero stats numbers (500+, 1800+, 4+) */
.stat-num {
  font-family: var(--font-body) !important;
  font-weight: 700 !important;
}
</style>



<script>
import * as THREE from 'three';
import { animate, inView, stagger, scroll } from 'https://cdn.jsdelivr.net/npm/motion@11/+esm';

document.addEventListener('DOMContentLoaded', () => {
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let mouseX = 0, mouseY = 0;
  let pointerX = window.innerWidth * 0.5;
  let pointerY = window.innerHeight * 0.5;

  document.addEventListener('mousemove', (e) => {
    mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
    mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
    pointerX = e.clientX;
    pointerY = e.clientY;
  });

  // === AMBIENT CURSOR AURORA ===
  if (!prefersReducedMotion && window.innerWidth > 960) {
    const aurora = document.createElement('div');
    aurora.className = 'cursor-aurora';
    aurora.style.transition = 'transform 0.12s linear';
    document.body.appendChild(aurora);
    document.body.classList.add('aurora-active');
    document.addEventListener('mousemove', (e) => {
      aurora.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0) translate(-50%, -50%)`;
    });
  }

  // === CUSTOM MORPHING CURSOR ===
  if (!prefersReducedMotion && window.innerWidth > 768) {
    const dot  = document.getElementById('cursor-dot')  as HTMLElement | null;
    const ring = document.getElementById('cursor-ring') as HTMLElement | null;
    let rx = 0, ry = 0;

    document.addEventListener('mousemove', (e) => {
      if (dot)  dot.style.transform  = `translate(${e.clientX - 4}px, ${e.clientY - 4}px)`;
      // Ring trails with lerp
      rx += (e.clientX - rx) * 0.18;
      ry += (e.clientY - ry) * 0.18;
    });

    let ringLast = 0;
    const followRing = (now: number) => {
      if (now - ringLast >= 33) { // ~30fps
        ringLast = now;
        if (ring) ring.style.transform = `translate(${rx - 18}px, ${ry - 18}px)`;
      }
      requestAnimationFrame(followRing);
    };
    requestAnimationFrame(followRing);

    // Morph states
    const setBtnCursor = () => { document.body.classList.add('cursor-btn'); document.body.classList.remove('cursor-card','cursor-link'); };
    const setCardCursor = () => { document.body.classList.add('cursor-card'); document.body.classList.remove('cursor-btn','cursor-link'); };
    const setLinkCursor = () => { document.body.classList.add('cursor-link'); document.body.classList.remove('cursor-btn','cursor-card'); };
    const clearCursor  = () => { document.body.classList.remove('cursor-btn','cursor-card','cursor-link'); };

    document.querySelectorAll('.btn, button').forEach(el => {
      el.addEventListener('mouseenter', setBtnCursor);
      el.addEventListener('mouseleave', clearCursor);
    });
    document.querySelectorAll('.service-card, .testimonial-card, .block-card, .about-card, .payment-card').forEach(el => {
      el.addEventListener('mouseenter', setCardCursor);
      el.addEventListener('mouseleave', clearCursor);
    });
    document.querySelectorAll('a:not(.btn)').forEach(el => {
      el.addEventListener('mouseenter', setLinkCursor);
      el.addEventListener('mouseleave', clearCursor);
    });
  }

  // === CINEMATIC SECTION AMBIENCE ===
  const sections = document.querySelectorAll('section');
  sections.forEach((section) => section.classList.add('cinematic-section'));
  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
      }
    });
  }, { threshold: 0.2 });
  sections.forEach((section) => sectionObserver.observe(section));

  // === HERO LETTER REVEAL ===
  if (!prefersReducedMotion) {
    const heroLines = document.querySelectorAll('.hero-line');
    heroLines.forEach((line, lineIdx) => {
      const txt = line.textContent || '';
      line.textContent = '';
      Array.from(txt).forEach((char, charIdx) => {
        const span = document.createElement('span');
        span.className = char === ' ' ? 'char space' : 'char';
        span.textContent = char;
        span.style.setProperty('--char-delay', `${lineIdx * 180 + charIdx * 28}ms`);
        line.appendChild(span);
      });
      requestAnimationFrame(() => line.classList.add('animate-in'));
    });
  }

  // === MAGNETIC BUTTON MICRO-INTERACTIONS ===
  if (!prefersReducedMotion) {
    document.querySelectorAll('.btn').forEach((button) => {
      const el = button as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
        const y = (e.clientY - rect.top - rect.height / 2) / rect.height;
        el.style.setProperty('--mag-x', `${x * 14}px`);
        el.style.setProperty('--mag-y', `${y * 12}px`);
        el.classList.add('magnetic-active');
      });
      el.addEventListener('mouseleave', () => {
        el.style.setProperty('--mag-x', '0px');
        el.style.setProperty('--mag-y', '0px');
        el.classList.remove('magnetic-active');
      });
    });
  }

  // === HERO 3D SCENE — PREMIUM NEBULA ===
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (canvas) {
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x070e1a, 0.018);
    const camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 120);
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: false });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.0));
    renderer.setClearColor(0x000000, 0);

    // ── LAYER 1: Far nebula cloud (5000 pts, tiny) ──
    const farGeo = new THREE.BufferGeometry();
    const farCount = 1500;
    const farPos = new Float32Array(farCount * 3);
    const farCol = new Float32Array(farCount * 3);
    const farSizes = new Float32Array(farCount);
    for (let i = 0; i < farCount; i++) {
      farPos[i*3]   = (Math.random() - 0.5) * 80;
      farPos[i*3+1] = (Math.random() - 0.5) * 50;
      farPos[i*3+2] = (Math.random() - 0.5) * 80 - 20;
      const isWhite = Math.random() > 0.75;
      const isgold  = !isWhite && Math.random() > 0.85;
      farCol[i*3]   = isWhite ? 0.9 : isgold ? 0.82 : 0.24;
      farCol[i*3+1] = isWhite ? 0.9 : isgold ? 0.66 : 0.49;
      farCol[i*3+2] = isWhite ? 0.95 : isgold ? 0.26 : 0.78;
      farSizes[i] = Math.random() * 0.06 + 0.015;
    }
    farGeo.setAttribute('position', new THREE.BufferAttribute(farPos, 3));
    farGeo.setAttribute('color',    new THREE.BufferAttribute(farCol, 3));
    const farMat = new THREE.PointsMaterial({
      size: 0.055, vertexColors: true, transparent: true,
      opacity: 0.9, sizeAttenuation: true, depthWrite: false
    });
    const farParticles = new THREE.Points(farGeo, farMat);
    scene.add(farParticles);

    // ── LAYER 2: Mid particles (1200 pts, brighter) ──
    const midGeo = new THREE.BufferGeometry();
    const midCount = 400;
    const midPos = new Float32Array(midCount * 3);
    const midCol = new Float32Array(midCount * 3);
    for (let i = 0; i < midCount; i++) {
      midPos[i*3]   = (Math.random() - 0.5) * 40;
      midPos[i*3+1] = (Math.random() - 0.5) * 25;
      midPos[i*3+2] = (Math.random() - 0.5) * 30 - 5;
      midCol[i*3]   = 0.35 + Math.random() * 0.2;
      midCol[i*3+1] = 0.6  + Math.random() * 0.2;
      midCol[i*3+2] = 0.88 + Math.random() * 0.1;
    }
    midGeo.setAttribute('position', new THREE.BufferAttribute(midPos, 3));
    midGeo.setAttribute('color',    new THREE.BufferAttribute(midCol, 3));
    const midMat = new THREE.PointsMaterial({
      size: 0.1, vertexColors: true, transparent: true,
      opacity: 1.0, sizeAttenuation: true, depthWrite: false
    });
    const midParticles = new THREE.Points(midGeo, midMat);
    scene.add(midParticles);

    // ── Grid floor ──
    const gridMat = new THREE.LineBasicMaterial({ color: 0x3d7ec7, transparent: true, opacity: 0.04 });
    for (let i = -15; i <= 15; i += 1.5) {
      scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(-20,-5,i),new THREE.Vector3(20,-5,i)]),gridMat));
      scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(i,-5,-20),new THREE.Vector3(i,-5,20)]),gridMat));
    }

    // ── Wireframe city skyline ──
    const bMatBlue  = new THREE.MeshBasicMaterial({ color: 0x5a9de0, wireframe: true, transparent: true, opacity: 0.07 });
    const bMatGold  = new THREE.MeshBasicMaterial({ color: 0xd4a843, wireframe: true, transparent: true, opacity: 0.05 });
    const buildings: THREE.Mesh[] = [];
    for (let i = 0; i < 18; i++) {
      const mat = i % 5 === 0 ? bMatGold : bMatBlue;
      const m = new THREE.Mesh(new THREE.BoxGeometry(1, 4, 1), mat);
      m.position.set((Math.random()-0.5)*30, -3+Math.random(), (Math.random()-0.5)*20-6);
      m.scale.set(0.3+Math.random()*0.9, 0.4+Math.random()*3.5, 0.3+Math.random()*0.9);
      scene.add(m); buildings.push(m);
    }

    // ── Floating premium geometries ──
    const mkMat = (col: number, op: number) => new THREE.MeshBasicMaterial({ color: col, wireframe: true, transparent: true, opacity: op });
    const floaters: THREE.Mesh[] = [];
    const geoConfigs = [
      { geo: new THREE.TorusGeometry(1.4, 0.25, 14, 48),    pos: [-8, 2, -6],  mat: mkMat(0x5a9de0, 0.14) },
      { geo: new THREE.IcosahedronGeometry(1.6, 1),          pos: [9, 1, -9],   mat: mkMat(0x5a9de0, 0.12) },
      { geo: new THREE.OctahedronGeometry(1.1, 0),           pos: [-5,-1,-4],   mat: mkMat(0xffffff, 0.07) },
      { geo: new THREE.DodecahedronGeometry(0.9, 0),         pos: [6, 3,-10],   mat: mkMat(0x5a9de0, 0.12) },
      { geo: new THREE.TorusKnotGeometry(0.8, 0.22, 80, 10), pos: [0,-3,-12],   mat: mkMat(0xd4a843, 0.09) },
      { geo: new THREE.SphereGeometry(2, 20, 20),            pos: [-4, 5,-18],  mat: mkMat(0x3d7ec7, 0.04) },
      { geo: new THREE.TetrahedronGeometry(1.2, 0),          pos: [12,-2,-8],   mat: mkMat(0x8bbef0, 0.1)  },
      { geo: new THREE.TorusGeometry(0.9, 0.18, 10, 36),     pos: [4, 6, -7],   mat: mkMat(0xd4a843, 0.07) },
    ];
    geoConfigs.forEach(({ geo, pos, mat }) => {
      const m = new THREE.Mesh(geo, mat);
      m.position.set(pos[0], pos[1], pos[2]);
      scene.add(m); floaters.push(m);
    });

    // ── Connection lines ──
    const lineMat = new THREE.LineBasicMaterial({ color: 0x5a9de0, transparent: true, opacity: 0.03 });
    for (let i = 0; i < floaters.length - 1; i++) {
      scene.add(new THREE.Line(
        new THREE.BufferGeometry().setFromPoints([floaters[i].position, floaters[i+1].position]),
        lineMat
      ));
    }

    // ── Glowing ring portal ──
    const portalRing = new THREE.Mesh(
      new THREE.TorusGeometry(3.5, 0.04, 8, 80),
      new THREE.MeshBasicMaterial({ color: 0x3d7ec7, transparent: true, opacity: 0.18 })
    );
    portalRing.position.set(0, 0, -12);
    scene.add(portalRing);
    const portalRing2 = new THREE.Mesh(
      new THREE.TorusGeometry(3.7, 0.02, 8, 80),
      new THREE.MeshBasicMaterial({ color: 0xd4a843, transparent: true, opacity: 0.09 })
    );
    portalRing2.position.set(0, 0, -12);
    scene.add(portalRing2);

    camera.position.set(0, 0, 8);
    const clock = new THREE.Clock();
    let heroLast = 0;
    const HERO_FPS = 30;
    const HERO_INTERVAL = 1000 / HERO_FPS;

    function animateHero(now: number) {
      requestAnimationFrame(animateHero);
      if (now - heroLast < HERO_INTERVAL) return;
      heroLast = now;
      const t = clock.getElapsedTime();

      farParticles.rotation.y = t * 0.012;
      farParticles.rotation.x = t * 0.004;
      midParticles.rotation.y = t * 0.022;
      midParticles.rotation.x = -t * 0.007;

      camera.position.x += (mouseX * 2.5 - camera.position.x) * 0.012;
      camera.position.y += (-mouseY * 1.5 - camera.position.y) * 0.012;
      camera.lookAt(0, 0, 0);

      buildings.forEach((b, i) => {
        b.rotation.y = t * 0.05 + i;
        b.position.y = -3 + Math.sin(t * 0.22 + i * 0.8) * 0.35;
      });

      floaters.forEach((f, i) => {
        f.rotation.x = t * (0.14 + i * 0.035);
        f.rotation.y = t * (0.09 + i * 0.028);
        f.rotation.z = t * (0.04 + i * 0.018);
        f.position.y += Math.sin(t * 0.38 + i * 1.3) * 0.002;
      });

      const pulse = 0.85 + Math.sin(t * 1.2) * 0.15;
      (portalRing.material as THREE.MeshBasicMaterial).opacity = 0.12 + pulse * 0.1;
      portalRing.rotation.z = t * 0.08;
      portalRing2.rotation.z = -t * 0.05;

      renderer.render(scene, camera);
    }
    requestAnimationFrame(animateHero);

    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });
  }

  // === TOUR CTA 3D WAVE SCENE ===
  const tourCanvas = document.getElementById('tour-canvas') as HTMLCanvasElement;
  if (tourCanvas) {
    const tScene = new THREE.Scene();
    const tCam = new THREE.PerspectiveCamera(60, 2, 0.1, 100);
    const tRend = new THREE.WebGLRenderer({ canvas: tourCanvas, alpha: true, antialias: false });
    tRend.setPixelRatio(Math.min(window.devicePixelRatio, 1.0));

    const planeGeo = new THREE.PlaneGeometry(30, 30, 30, 30);
    const planeMat = new THREE.MeshBasicMaterial({ color: 0x3d7ec7, wireframe: true, transparent: true, opacity: 0.08 });
    const plane = new THREE.Mesh(planeGeo, planeMat);
    plane.rotation.x = -Math.PI / 2.5;
    plane.position.y = -2;
    plane.position.z = -8;
    tScene.add(plane);

    const ptsGeo = new THREE.BufferGeometry();
    const ptCount = 300;
    const ptPos = new Float32Array(ptCount * 3);
    for (let i = 0; i < ptCount * 3; i += 3) {
      ptPos[i] = (Math.random() - 0.5) * 20;
      ptPos[i+1] = (Math.random() - 0.5) * 10;
      ptPos[i+2] = (Math.random() - 0.5) * 20 - 5;
    }
    ptsGeo.setAttribute('position', new THREE.BufferAttribute(ptPos, 3));
    const ptsMat = new THREE.PointsMaterial({ color: 0x8bbef0, size: 0.04, transparent: true, opacity: 0.5 });
    tScene.add(new THREE.Points(ptsGeo, ptsMat));

    const tTorus = new THREE.Mesh(new THREE.TorusGeometry(2, 0.15, 12, 60), new THREE.MeshBasicMaterial({ color: 0x5a9de0, wireframe: true, transparent: true, opacity: 0.1 }));
    tTorus.position.set(0, 0, -10);
    tScene.add(tTorus);

    tCam.position.set(0, 3, 6);
    tCam.lookAt(0, 0, -5);

    const tClock = new THREE.Clock();
    const posArr = planeGeo.attributes.position;

    function sizeTourCanvas() {
      const parent = tourCanvas.parentElement!;
      tRend.setSize(parent.clientWidth, parent.clientHeight);
      tCam.aspect = parent.clientWidth / parent.clientHeight;
      tCam.updateProjectionMatrix();
    }
    sizeTourCanvas();

    let tourLast = 0;
    const TOUR_INTERVAL = 1000 / 24;

    function animateTour(now: number) {
      requestAnimationFrame(animateTour);
      if (now - tourLast < TOUR_INTERVAL) return;
      tourLast = now;
      const t = tClock.getElapsedTime();
      for (let i = 0; i < posArr.count; i++) {
        const x = posArr.getX(i);
        const z = posArr.getZ(i);
        posArr.setY(i, Math.sin(x * 0.4 + t * 0.8) * 0.3 + Math.cos(z * 0.3 + t * 0.6) * 0.3);
      }
      posArr.needsUpdate = true;
      tTorus.rotation.x = t * 0.2;
      tTorus.rotation.y = t * 0.15;
      tRend.render(tScene, tCam);
    }
    requestAnimationFrame(animateTour);
    window.addEventListener('resize', sizeTourCanvas);
  }

  // === 3D TILT CARDS ===
  document.querySelectorAll('.tilt-card').forEach(card => {
    const el = card as HTMLElement;
    const shine = el.querySelector('.tilt-shine') as HTMLElement | null;
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = el.getBoundingClientRect();
      const cx = e.clientX - rect.left;
      const cy = e.clientY - rect.top;
      const rx = ((cy / rect.height) - 0.5) * -12;
      const ry = ((cx / rect.width) - 0.5) * 12;
      el.style.transform = `perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-10px) scale(1.02)`;
      if (shine) {
        shine.style.setProperty('--shine-x', `${(cx / rect.width) * 100}%`);
        shine.style.setProperty('--shine-y', `${(cy / rect.height) * 100}%`);
      }
    });
    el.addEventListener('mouseleave', () => {
      el.style.transform = '';
    });
  });

  // === NAVBAR ===
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (navbar) navbar.classList.toggle('scrolled', window.scrollY > 50);
  });

  // === HAMBURGER ===
  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('navLinks');
  hamburger?.addEventListener('click', () => navLinks?.classList.toggle('open'));
  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => navLinks.classList.remove('open'));
  });

  // === COUNTERS ===
  const statNums = document.querySelectorAll('.stat-num');
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0');
        let current = 0;
        const increment = target / 60;
        const timer = setInterval(() => {
          current += increment;
          if (current >= target) { el.textContent = target.toLocaleString(); clearInterval(timer); }
          else { el.textContent = Math.floor(current).toLocaleString(); }
        }, 25);
        counterObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });
  statNums.forEach(el => counterObserver.observe(el));

  // === SCROLL REVEAL ===
  // === SCROLL REVEAL ===
  const revealEls = document.querySelectorAll(
    '.hero-badge, .hero-title, .hero-desc, .hero-btns, .hero-stats, .about-features, .about-card, .service-card, .project-main, .project-amenities, .block-card, .payment-card, .amenity-mini, .contact-item, .contact-form-wrap, .size-tag, .tour-cta-content'
  );
  revealEls.forEach(el => el.classList.add('reveal'));
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.05 });
  revealEls.forEach(el => revealObserver.observe(el));

  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button[type="submit"]') as HTMLButtonElement;
    if (!btn) return;
    btn.textContent = '✓ Message Sent!';
    btn.style.background = 'linear-gradient(135deg, #27ae60, #2ecc71)';
    setTimeout(() => {
      btn.textContent = 'Send Message';
      btn.style.background = '';
      (e.target as HTMLFormElement).reset();
    }, 3500);
  });

  // === SCROLL PROGRESS BAR ===
  const progressBar = document.getElementById('scroll-progress');
  window.addEventListener('scroll', () => {
    if (progressBar) {
      const pct = (window.scrollY / (document.body.scrollHeight - window.innerHeight)) * 100;
      progressBar.style.width = `${Math.min(pct, 100)}%`;
    }
  });

  // ===   // ============================================================
  // === MOTION.DEV (FRAMER MOTION VANILLA) SCROLL ANIMATIONS ===
  // ============================================================
  if (!prefersReducedMotion) {

    // --- SERVICES: Staggered card entrance from below ---
    // --- SERVICES: 3D flip-in from flat + icon orbit ---
    inView('#services .services-grid', () => {
      animate(
        '#services .services-header',
        { opacity: [0.5, 1], y: [-20, 0] },
        { duration: 0.2, easing: [0.25, 0.46, 0.45, 0.94] }
      );
      animate(
        '#services .service-card',
        { opacity: [0.4, 1], y: [40, 0], scale: [0.95, 1] },
        { duration: 0.25, delay: stagger(0.06), easing: [0.34, 1.56, 0.64, 1] }
      );
    }, { amount: 0.12 });

    // --- ABOUT: Left slides in from left, card slides from right ---
    inView('#about .about-left', () => {
      animate('#about .about-left', { opacity: [0.5, 1], x: [-30, 0] }, { duration: 0.22, easing: [0.25, 0.46, 0.45, 0.94] });
      animate('#about .about-right', { opacity: [0.5, 1], x: [30, 0] }, { duration: 0.22, delay: 0.06, easing: [0.25, 0.46, 0.45, 0.94] });
    }, { amount: 0.25 });

    // --- CEO: Split text title + 3D frame drop + values cascade ---
    inView('#ceo .ceo-grid', () => {
      animate('#ceo .ceo-frame', { scale: [0.9, 1], y: [-20, 0] }, { duration: 0.25, easing: [0.34, 1.56, 0.64, 1] });
      animate('#ceo .ceo-value', { x: [-20, 0] }, { duration: 0.2, delay: stagger(0.06, { start: 0.1 }), easing: [0.25, 0.46, 0.45, 0.94] });
      animate('#ceo .value-icon', { scale: [0.8, 1] }, { duration: 0.18, delay: stagger(0.06, { start: 0.12 }), easing: [0.34, 1.56, 0.64, 1] });
    }, { amount: 0.15 });

    // --- TESTIMONIALS: header + cards ---
    inView('#testimonials .testimonials-header', () => {
      animate('#testimonials .testimonials-header h2', { y: [-10, 0] }, { duration: 0.2, easing: [0.34, 1.56, 0.64, 1] });
      animate('#testimonials .accent-line', { scaleX: [0, 1] }, { duration: 0.2, delay: 0.05, easing: [0.25, 0.46, 0.45, 0.94] });
    }, { amount: 0.3 });

    inView('#testimonials .testimonials-grid', () => {
      animate('#testimonials .testimonial-card',
        { opacity: [0.5, 1], y: [20, 0], scale: [0.96, 1] },
        { duration: 0.2, delay: stagger(0.05), easing: [0.34, 1.56, 0.64, 1] }
      );
    }, { amount: 0.15 });

    document.querySelectorAll('.testimonial-card').forEach(card => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const r = el.getBoundingClientRect();
        const x = e.clientX - r.left;
        const y = e.clientY - r.top;
        const rotY = ((x / r.width) - 0.5) * 14;
        const rotX = -((y / r.height) - 0.5) * 10;
        el.style.transform = `perspective(900px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateY(-8px) scale(1.02)`;
        const shine = el.querySelector('.tilt-shine') as HTMLElement | null;
        if (shine) { shine.style.opacity = '1'; shine.style.background = `radial-gradient(circle at ${x}px ${y}px, rgba(255,255,255,0.1), transparent 65%)`; }
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = '';
        const shine = el.querySelector('.tilt-shine') as HTMLElement | null;
        if (shine) shine.style.opacity = '0';
      });
    });

    // --- BLOCKS: fast snap-in with stagger ---
    inView('#blocks .blocks-grid', () => {
      animate(
        '#blocks .block-card',
        { opacity: [0.4, 1], y: [30, 0], scale: [0.94, 1] },
        { duration: 0.18, delay: stagger(0.04), easing: [0.22, 1, 0.36, 1] }
      );
    }, { amount: 0.1 });

    // --- BLOCKS SIZE TAGS ---
    inView('#blocks .size-tags', () => {
      animate('#blocks .size-tag', { opacity: [0.5, 1], y: [15, 0] }, { duration: 0.15, delay: stagger(0.04), easing: [0.25, 0.46, 0.45, 0.94] });
    }, { amount: 0.4 });

    // --- PAYMENT: Holographic 3D entrance + stagger features ---
    inView('#payment .payment-layout', () => {
      animate(
        '#payment .payment-info',
        { opacity: [0, 1], x: [-90, 0], filter: ['blur(8px)', 'blur(0px)'] },
        { duration: 0.9, easing: [0.25, 0.46, 0.45, 0.94] }
      );
      animate(
        '#payment .payment-card',
        {
          opacity:  [0, 1],
          scale:    [0.75, 1],
          rotateY:  ['-22deg', '0deg'],
          y:        [80, 0]
        },
        { duration: 1.05, delay: 0.2, easing: [0.34, 1.56, 0.64, 1] }
      );
      // stagger feature list items in
      document.querySelectorAll('#payment .payment-features li').forEach((el, i) => {
        setTimeout(() => el.classList.add('pay-visible'), 700 + i * 130);
      });
    }, { amount: 0.2 });



    // --- TOUR CTA: Zoom-in fade ---
    inView('#tour-cta .tour-cta-content', () => {
      animate(
        '#tour-cta .tour-cta-content',
        { opacity: [0, 1], scale: [0.9, 1], y: [40, 0] },
        { duration: 0.9, easing: [0.34, 1.56, 0.64, 1] }
      );
    }, { amount: 0.3 });

    // --- CONTACT: Split entrance ---
    inView('#contact .contact-grid', () => {
      animate(
        '#contact .contact-info',
        { opacity: [0, 1], x: [-60, 0] },
        { duration: 0.75, easing: [0.25, 0.46, 0.45, 0.94] }
      );
      animate(
        '#contact .contact-form-wrap',
        { opacity: [0, 1], x: [60, 0] },
        { duration: 0.75, delay: 0.15, easing: [0.25, 0.46, 0.45, 0.94] }
      );
    }, { amount: 0.2 });

    // --- PROJECTS: 3D split entrance + badge + plot tags spring + amenity scatter ---
    inView('#projects .project-showcase', () => {
      animate(
        '#projects .project-main',
        { opacity: [0, 1], x: [-90, 0], rotateY: ['-10deg', '0deg'] },
        { duration: 1.0, easing: [0.25, 0.46, 0.45, 0.94] }
      );
      animate(
        '#projects .project-amenities',
        { opacity: [0, 1], x: [90, 0] },
        { duration: 1.0, delay: 0.15, easing: [0.25, 0.46, 0.45, 0.94] }
      );
      animate(
        '#projects .project-badge',
        { opacity: [0, 1], scale: [0, 1.3, 1], y: [-24, 0] },
        { duration: 0.75, delay: 0.35, easing: [0.34, 1.56, 0.64, 1] }
      );
      document.querySelectorAll('#projects .plot-tag').forEach((el, i) => {
        setTimeout(() => el.classList.add('pt-visible'), 500 + i * 90);
      });
      animate(
        '#projects .amenity-mini',
        { opacity: [0, 1], scale: [0.4, 1.15, 1], rotate: ['-18deg', '4deg', '0deg'] },
        { duration: 0.65, delay: stagger(0.055, { start: 0.6 }), easing: [0.34, 1.56, 0.64, 1] }
      );
    }, { amount: 0.1 });

    // --- MARQUEE STRIP: Fade in on load ---
    animate(
      '.marquee-strip',
      { opacity: [0, 1], y: [-20, 0] },
      { duration: 0.9, delay: 0.4, easing: [0.25, 0.46, 0.45, 0.94] }
    );

    // --- 3D TILT: Service cards mouse tracking ---
    document.querySelectorAll('#services .service-card').forEach(card => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const r = el.getBoundingClientRect();
        const x = e.clientX - r.left;
        const y = e.clientY - r.top;
        const cx = r.width  / 2;
        const cy = r.height / 2;
        const rotY =  ((x - cx) / cx) * 8;
        const rotX = -((y - cy) / cy) * 6;
        el.style.transform = `perspective(900px) rotateX(${rotX}deg) rotateY(${rotY}deg) translateY(-8px) scale(1.02)`;
        const shine = el.querySelector('.tilt-shine') as HTMLElement | null;
        if (shine) { shine.style.opacity = '1'; shine.style.background = `radial-gradient(circle at ${x}px ${y}px, rgba(255,255,255,0.12), transparent 70%)`; }
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = '';
        const shine = el.querySelector('.tilt-shine') as HTMLElement | null;
        if (shine) shine.style.opacity = '0';
      });
    });
  }

  // === ACTIVE NAV PILL ===
  const navLinksEl = document.getElementById('navLinks');
  const pill = document.createElement('div');
  pill.id = 'nav-pill';
  navLinksEl?.appendChild(pill);

  function updatePill(activeA: HTMLAnchorElement) {
    const navRect = navLinksEl!.getBoundingClientRect();
    const aRect   = activeA.getBoundingClientRect();
    pill.style.left  = (aRect.left - navRect.left) + 'px';
    pill.style.width = aRect.width + 'px';
  }

  const sectionIds = ['about','ceo','services','projects','blocks','payment','contact'];
  const navAnchors = Array.from(document.querySelectorAll('#navLinks a[href^="#"]')) as HTMLAnchorElement[];

  const activeSectionObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const id = entry.target.id;
      navAnchors.forEach(a => a.classList.remove('nav-active'));
      const active = navAnchors.find(a => a.getAttribute('href') === '#' + id);
      if (active) { active.classList.add('nav-active'); updatePill(active); }
    });
  }, { threshold: 0.35 });

  sectionIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) activeSectionObserver.observe(el);
  });

  navAnchors.forEach(a => {
    a.addEventListener('click', () => {
      navAnchors.forEach(x => x.classList.remove('nav-active','nav-click-flash'));
      a.classList.add('nav-active','nav-click-flash');
      updatePill(a);
      setTimeout(() => a.classList.remove('nav-click-flash'), 600);
    });
  });

});
</script>
