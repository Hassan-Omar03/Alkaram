.cinematic-section {
  position: relative;
  isolation: isolate;
}
.cinematic-section::before,
.cinematic-section::after {
  content: '';
  position: absolute;
  width: 360px;
  height: 360px;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
  opacity: 0;
  filter: blur(70px);
  transition: opacity 1.2s ease, transform 1.2s var(--ease-premium);
}
.cinematic-section::before {
  top: -180px;
  right: -120px;
  background: radial-gradient(circle, rgba(90,157,224,0.2) 0%, rgba(90,157,224,0) 68%);
  transform: scale(0.7);
}
.cinematic-section::after {
  bottom: -200px;
  left: -120px;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0) 68%);
  transform: scale(0.74);
}
.cinematic-section.in-view::before,
.cinematic-section.in-view::after {
  opacity: 1;
  transform: scale(1);
}

.section > * {
  position: relative;
  z-index: 1;
}

.section-title {
  position: relative;
  display: inline-block;
  overflow: hidden;
}
.section-title::after {
  content: '';
  position: absolute;
  inset: 0;
  transform: translateX(0);
  background: linear-gradient(100deg, rgba(7,14,26,0.96), rgba(7,14,26,0.82));
  transition: transform 1.1s var(--ease-premium);
}
.section-title.visible::after {
  transform: translateX(108%);
}

.btn {
  will-change: transform;
}
.btn.magnetic-active {
  box-shadow: 0 16px 35px rgba(61,126,199,0.25), 0 0 0 1px rgba(255,255,255,0.12);
}

/* ===== REVEAL ANIMATIONS ===== */
.reveal {
  opacity: 0;
  transform: translateY(35px);
  transition: opacity 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeInScale {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}
.tilt-card {
  transform-style: preserve-3d;
  perspective: 1000px;
}
.tilt-card-inner {
  transition: transform 0.15s ease-out;
  transform-style: preserve-3d;
}
.tilt-shine {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at var(--shine-x, 50%) var(--shine-y, 50%), rgba(255,255,255,0.06) 0%, transparent 60%);
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.3s;
  z-index: 2;
}
.tilt-card:hover .tilt-shine { opacity: 1; }

@media (prefers-reduced-motion: reduce) {
  .cursor-aurora,
  .cinematic-section::before,
  .cinematic-section::after,
  .hero-line .char {
    transition: none !important;
    animation: none !important;
  }
  .hero-line .char {
    transform: none;
    opacity: 1;
    filter: none;
  }
}

/* CEO section entrance — start hidden, Motion.dev reveals */
#ceo .ceo-frame,
#ceo .ceo-role,
#ceo .ceo-value,
#ceo .value-icon,
#ceo .ceo-info .section-title {
  opacity: 0;
