.marquee-strip::before,
.marquee-strip::after {
  content: '';
  position: absolute;
  top: 0; bottom: 0;
  width: 80px;
  z-index: 2;
  pointer-events: none;
}
.marquee-strip::before {
  left: 0;
  background: linear-gradient(90deg, var(--navy-2), transparent);
}
.marquee-strip::after {
  right: 0;
  background: linear-gradient(-90deg, var(--navy-2), transparent);
}
.marquee-track {
  display: flex;
  align-items: center;
  gap: 0;
  white-space: nowrap;
  animation: marqueeScroll 30s linear infinite;
  width: max-content;
}
.marquee-track span {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  padding: 0 24px;
  transition: color 0.3s;
}
.marquee-track span:hover { color: var(--blue-lighter); }
.marquee-dot {
  color: var(--gold) !important;
  font-size: 0.55rem !important;
  padding: 0 !important;
  letter-spacing: 0 !important;
  opacity: 0.7;
}
@keyframes marqueeScroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ===== TESTIMONIALS ===== */
#testimonials {
  position: relative;
  overflow: hidden;
  height: 100vh;
  min-height: 100vh;
  max-height: 100vh;
  display: flex;
  align-items: center;
}
#testimonials > .section {
  width: 100%;
  padding-top: clamp(52px, 7vh, 86px) !important;
  padding-bottom: clamp(52px, 7vh, 86px) !important;
  box-sizing: border-box;
}

@keyframes testimonialsOrb {
  0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.6; }
  50% { transform: translateX(-50%) scale(1.2); opacity: 1; }
}
.testimonials-header {
  text-align: center;
  margin-bottom: clamp(16px, 2.5vh, 36px);
  position: relative;
  z-index: 1;
}
.testimonials-header h2 {
  background: linear-gradient(135deg, var(--white) 0%, var(--blue-lighter) 50%, var(--white) 100%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmerText 4s linear infinite;
}
@keyframes shimmerText {
  0% { background-position: 0% center; }
  100% { background-position: 200% center; }
}
.testimonials-header .accent-line {
  margin: clamp(8px, 1.2vh, 16px) auto;
}
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: clamp(14px, 2vw, 28px);
  position: relative;
  z-index: 1;
}
.testimonial-card {
  background: rgba(12, 21, 38, 0.45);
  border: 1px solid rgba(90, 157, 224, 0.13);
  padding: clamp(16px, 2.2vh, 32px) clamp(16px, 2vw, 28px);
  position: relative;
  overflow: hidden;
  transition: border-color var(--transition-medium), box-shadow var(--transition-medium), transform var(--transition-medium);
  backdrop-filter: blur(22px) saturate(1.6);
  -webkit-backdrop-filter: blur(22px) saturate(1.6);
  border-radius: 20px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.32), inset 0 1px 0 rgba(255,255,255,0.07);
}
.testimonial-card:nth-child(1) { animation-delay: 0s; }
.testimonial-card:nth-child(2) { animation-delay: 1s; }
.testimonial-card:nth-child(3) { animation-delay: 2s; }
@keyframes floatTestimonial {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-7px); }
}
/* shimmer sweep on card */
.testimonial-card::after {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 60%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
  animation: cardShimmer 6s ease-in-out infinite;
  pointer-events: none;
}
.testimonial-card:nth-child(2)::after { animation-delay: 2s; }
.testimonial-card:nth-child(3)::after { animation-delay: 4s; }
@keyframes cardShimmer {
  0% { left: -100%; }
  50%, 100% { left: 150%; }
}
.testimonial-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--blue-dark), var(--blue-light), var(--gold));
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.5s var(--ease-premium);
}
.testimonial-card:hover::before { transform: scaleX(1); }
.testimonial-card:hover {
  border-color: rgba(61,126,199,0.3);
  box-shadow: 0 30px 60px rgba(0,0,0,0.4), 0 0 50px rgba(61,126,199,0.1);
}
.testimonial-quote {
  font-size: clamp(2rem, 3.5vh, 3.5rem);
  line-height: 1;
  color: var(--blue);
  opacity: 0.25;
  margin-bottom: clamp(10px, 1.5vh, 20px);
  font-family: Georgia, serif;
}
.testimonial-text {
  font-size: clamp(0.8rem, 1.4vh, 0.95rem);
  color: var(--gray-light);
  line-height: 1.7;
  margin-bottom: clamp(14px, 2vh, 28px);
  font-style: italic;
}
.testimonial-author {
  display: flex;
  align-items: center;
  gap: 14px;
  padding-top: clamp(10px, 1.5vh, 20px);
  border-top: 1px solid rgba(255,255,255,0.05);
}
.author-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--blue-dark), var(--blue));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  flex-shrink: 0;
  border: 1px solid rgba(90,157,224,0.3);
}
.author-name {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--white-soft);
}
.author-role {
  font-size: 0.75rem;
  color: var(--gray);
  margin-top: 2px;
}
.testimonial-stars {
  margin-left: auto;
  color: var(--gold);
  font-size: 0.9rem;
  letter-spacing: 2px;
  flex-shrink: 0;
  animation: starPop 0.4s ease-out;
