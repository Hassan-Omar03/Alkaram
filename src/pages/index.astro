      const ptsMat = new THREE.PointsMaterial({ color: 0x8bbef0, size: 0.04, transparent: true, opacity: 0.5 });
      tScene.add(new THREE.Points(ptsGeo, ptsMat));

      const tTorus = new THREE.Mesh(new THREE.TorusGeometry(2, 0.15, 8, 40), new THREE.MeshBasicMaterial({ color: 0x5a9de0, wireframe: true, transparent: true, opacity: 0.1 }));
      tTorus.position.set(0, 0, -10);
