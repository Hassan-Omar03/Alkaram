        const t=ctClock.getElapsedTime();
        ctFPts.rotation.y=t*.012; ctFPts.rotation.x=t*.004;
        ctCam.position.x+=(mouseX*2.5-ctCam.position.x)*.012;
        ctCam.position.y+=(-mouseY*1.5-ctCam.position.y)*.012;
        ctCam.lookAt(0,0,0); ctRend.render(ctScene,ctCam);
      };
      requestAnimationFrame(animContact);
    };
    new IntersectionObserver((entries)=>entries.forEach(e=>{contactVisible=e.isIntersecting;if(e.isIntersecting)initContact();}),{threshold:.05}).observe(document.getElementById('contact')!);
  }

