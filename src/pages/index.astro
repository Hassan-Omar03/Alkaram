          <a href="https://aljalildevelopers.com/pages/al-jalil-garden-housing-scheme" target="_blank" class="btn btn-outline">Visit Official Site</a>
        </div>
      </div>
      <div class="project-amenities">
        <div class="amenities-header">
          <span class="amenities-label">Lifestyle</span>
          <h3>World-Class Amenities</h3>
          <div class="amenities-accent"></div>
        </div>
        <div class="amenities-grid-mini">
          <div class="amenity-mini">
            <span class="ami">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
