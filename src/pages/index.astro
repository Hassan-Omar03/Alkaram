      tCam.position.set(0, 3, 6);
      tCam.lookAt(0, 0, -5);

      const tClock = new THREE.Clock();
      const posArr = planeGeo.attributes.position;

      const sizeTourCanvas = () => {
        const parent = tourCanvas.parentElement!;
