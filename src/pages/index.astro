  pointer-events: none;
  background:
    radial-gradient(circle at 12% 28%, rgba(139, 190, 240, 0.18) 0 1px, transparent 2px),
    radial-gradient(circle at 84% 22%, rgba(255, 255, 255, 0.12) 0 1px, transparent 2px),
    linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
  opacity: 0.65;
}
.nav-logo {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}
.nav-logo-img {
  width: clamp(76px, 7.2vw, 104px);
  height: auto;
  max-height: 36px;
  display: block;
  object-fit: contain;
  border-radius: 6px;
  padding: 2px 4px;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s;
}
.nav-logo-img:hover {
  transform: scale(1.05);
  box-shadow: 0 4px 20px rgba(61,126,199,0.2);
}
.nav-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: clamp(12px, 1vw, 18px);
}
.nav-links a {
  font-size: 0.76rem;
  font-weight: 500;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  transition: all var(--transition-fast);
  position: relative;
  overflow: hidden;
  border-radius: 999px;
  padding: 8px 8px; /* thoda increase for bubble */
  isolation: isolate;
  
  overflow: hidden;
}
/* Glass background layer */
.nav-links a::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12px) saturate(1.4);
  -webkit-backdrop-filter: blur(12px) saturate(1.4);
  border: 1px solid rgba(255,255,255,0.15);
  opacity: 0;
  transition: opacity var(--transition-fast), transform var(--transition-fast);
  z-index: -1;
}
/* Glass background layer */
.nav-links a::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12px) saturate(1.4);
  -webkit-backdrop-filter: blur(12px) saturate(1.4);
  border: 1px solid rgba(255,255,255,0.15);
  opacity: 0;
  transition: opacity var(--transition-fast), transform var(--transition-fast);
  z-index: -1;
}

/* Hover effect */
.nav-links a:hover::before {
  opacity: 1;
transform: none;
}

.nav-links a:hover {
  color: var(--white);
  transform: translateY(-1px);
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 1.5px;
  background: var(--white);
  transition: width var(--transition-fast);
}
.nav-links a:hover { color: var(--white); }
.nav-links a:hover {
  transform: translateY(-1px);
}
.nav-links a:hover::after { width: 100%; }
.nav-links { position: relative; }
.nav-tour-btn::after { display: none !important; }
.nav-tour-btn.btn {
  height: 36px;
  min-height: 36px;
  padding: 0 12px;
  font-size: 0.66rem;
  line-height: 1;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
}

.nav-links a::before {
  content: '';
  position: absolute;
  inset: 2;
  border-radius: inherit;
  background: radial-gradient(circle at 50% 35%, rgba(255,255,255,0.22) 0%, rgba(255,255,255,0.08) 24%, rgba(255,255,255,0) 62%);
  opacity: 0;
  transform: scale(0.6);
  transition: opacity 0.28s ease, transform 0.28s ease;
  z-index: -1;
}

.nav-links a:hover::before {
  opacity: 1;
  transform: scale(1);
}

.nav-tour-btn {
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 8px 24px rgba(61,126,199,0.18);
}

.nav-tour-btn:hover {
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.16), 0 10px 28px rgba(61,126,199,0.26);
}
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 5px;
}
.hamburger span {
  width: 25px;
  height: 2px;
  background: var(--blue-light);
  transition: all 0.3s;
}

.cursor-aurora {
  position: fixed;
  top: 0;
  left: 0;
  width: 280px;
  height: 280px;
  pointer-events: none;
  z-index: 30;
  border-radius: 50%;
  opacity: 0;
  transform: translate3d(-50%, -50%, 0) scale(0.9);
  background:
    radial-gradient(circle at 35% 35%, rgba(255,255,255,0.28), rgba(255,255,255,0) 45%),
    radial-gradient(circle at 60% 60%, rgba(90,157,224,0.4), rgba(90,157,224,0) 70%);
  filter: blur(18px);
  mix-blend-mode: screen;
  transition: opacity 0.45s ease, transform 0.35s ease;
}

body.aurora-active .cursor-aurora {
  opacity: 0.62;
}

/* ===== HERO ===== */
#hero {
  position: relative;
  min-height: calc(100vh - 105px);
  height: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 80px 0 36px;
  box-sizing: border-box;
  overflow: visible;
}
#hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
}
.hero-particles-overlay {
  display: none;
}
.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
   padding: 0 5% 20px;
  max-width: 900px;
  width: 100%;
  flex-shrink: 0;
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 3px;
  color: rgba(255,255,255,0.85);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 8px 20px;
  margin-bottom: clamp(12px, 2vh, 24px);
  text-transform: uppercase;
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(8px);
  border-radius: 50px;
}
.badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--blue-light);
  animation: dotPulse 2s ease-in-out infinite;
}
@keyframes dotPulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(90,157,224,0.4); }
  50% { opacity: 0.6; box-shadow: 0 0 0 6px rgba(90,157,224,0); }
}
.hero-title {
  font-family: var(--font-heading);
  font-size: clamp(1.5rem, 3vw, 3rem);
  font-weight: 500;
  line-height: 1.1;
  margin-bottom: clamp(10px, 1.5vh, 20px);
  text-shadow: 0 0 80px rgba(90,157,224,0.3);
}
.hero-line { display: block; }
.hero-line .char {
  display: inline-block;
  transform: translateY(120%) rotate(4deg);
  opacity: 0;
  filter: blur(8px);
  transition: transform 0.9s var(--ease-premium), opacity 0.8s ease, filter 0.8s ease;
  transition-delay: var(--char-delay, 0ms);
}
.hero-line .char.space {
  width: 0.26em;
}
.hero-line.animate-in .char {
  transform: translateY(0) rotate(0);
  opacity: 1;
  filter: blur(0);
}
.hero-line.accent {
  background: linear-gradient(90deg, var(--blue-light), var(--blue-lighter), rgba(255,255,255,0.9));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-desc {
  font-size: clamp(0.85rem, 1.4vh, 1rem);
  color: var(--gray-light);
  max-width: 600px;
  margin: 0 auto clamp(16px, 2.5vh, 32px);
  line-height: 1.7;
}
.hero-btns {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
  
}

/* Desktop: Show full text, hide short text */
.btn-text-short { display: none; }
.btn-text-full { display: inline; }

.stat { text-align: center; }
.glass-stat {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 12px;
  padding: 6px 12px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 4px 24px rgba(0,0,0,0.3);
  position: relative;
}
.glass-stat::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 16px;
  background: linear-gradient(135deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0.03) 50%, transparent 100%);
  pointer-events: none;
}
.stat-num {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  color: var(--white);
}
.stat-plus {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  color: rgba(255,255,255,0.6);
}
.stat-label {
  display: block;
  font-size: 0.65rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--gray);
}
.stat-divider {
  width: 1px;
  height: 50px;
  background: rgba(61,126,199,0.2);
}
.scroll-indicator {
  position: absolute;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}
.scroll-indicator span {
  font-size: 0.65rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gray);
}
.scroll-line {
  width: 1px;
  height: 40px;
  background: linear-gradient(to bottom, var(--blue-light), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}
@keyframes scrollPulse {
  0%, 100% { opacity: 1; transform: scaleY(1); }
  50% { opacity: 0.3; transform: scaleY(0.5); }
}


/* ===== ABOUT ===== */
#about {
  background: linear-gradient(180deg, var(--navy-2) 0%, var(--navy-3) 100%);
  position: relative;
  overflow: hidden;
}
#about::before {
  content: '';
  position: absolute;
  top: -200px;
  right: -200px;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(61,126,199,0.09) 0%, transparent 70%);
  pointer-events: none;
}
#about::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.25), transparent);
}
.about-grid {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 80px;
  align-items: stretch;
}
.about-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 32px;
}
.about-feature {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 0.9rem;
  font-weight: 500;
}
.about-right { display: flex; justify-content: start; align-items:start; }
.about-card {
  width: 320px;
  position: relative;
}
.about-card-inner {
  width: 100%;
  background: rgba(255,255,255,0.08) !important;
  border: 1px solid rgba(255,255,255,0.25) !important;
  backdrop-filter: blur(40px) saturate(2) !important;
  -webkit-backdrop-filter: blur(40px) saturate(2) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.2), 0 8px 32px rgba(0,0,0,0.35) !important;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 44px 40px;
  text-align: center;
  transition: all var(--transition-slow);
  position: relative;
  z-index: 1;
  border-radius: 18px;
}
.about-card-inner:hover {
  transform: translateY(-12px) scale(1.02);
  box-shadow: 0 35px 70px rgba(0,0,0,0.35), 0 0 60px rgba(61,126,199,0.08);
  border-color: rgba(255,255,255,0.12);
}
.about-logo-img {
  width: 180px;
  height: auto;
  margin-bottom: 20px;
  border-radius: 8px;
  transition: transform var(--transition-medium);
}
.about-card-inner:hover .about-logo-img {
  transform: scale(1.05);
}
.about-card-glow {
  position: absolute;
  inset: -1px;
  background: linear-gradient(135deg, rgba(61,126,199,0.2), transparent, rgba(90,157,224,0.1));
  z-index: 0;
  filter: blur(20px);
  opacity: 0;
  transition: opacity 0.6s;
}
.about-card:hover .about-card-glow { opacity: 1; }
.card-divider {
  width: 40px;
  height: 2px;
  background: linear-gradient(90deg, var(--blue), var(--blue-light));
  margin: 20px 0;
}
.card-parent-label {
  display: block;
  font-size: 0.65rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--gray);
  margin-bottom: 4px;
}
.card-parent-name {
  font-size: 1rem;
  font-weight: 600;
  color: var(--blue-light);
}

/* ===== CEO ===== */
#ceo {
  position: relative;
  overflow: hidden;
  padding-top: 200px !important;
  padding-bottom: 200px !important;
}
#ceo-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.ceo-grid {
  display: grid;
  grid-template-columns: 0.7fr 1.3fr;
  gap: 80px;
  align-items: stretch;
}
.ceo-visual { display: flex; justify-content: center; align-items: center; }
.ceo-frame {
  width: 260px;
  height: 320px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.08);
}
.ceo-frame-border {
  position: absolute;
  inset: -2px;
  border: 2px solid transparent;
  background: linear-gradient(135deg, var(--blue), var(--blue-dark), var(--blue-light)) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}
.ceo-initials {
  font-family: var(--font-heading);
  font-size: 4rem;
  font-weight: 700;
  background: linear-gradient(135deg, var(--blue-light), var(--blue-lighter));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  opacity: 0.85;
  position: relative;
  z-index: 2;
  animation: ceoInitialsPulse 3s ease-in-out infinite;
}
@keyframes ceoInitialsPulse {
  0%, 100% { text-shadow: 0 0 30px rgba(90,157,224,0.3); }
  50% { text-shadow: 0 0 60px rgba(90,157,224,0.7), 0 0 100px rgba(90,157,224,0.3); }
}
/* CEO orb particles */
.ceo-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(40px);
  pointer-events: none;
  z-index: 0;
}
.ceo-orb-1 {
  width: 160px; height: 160px;
  background: rgba(61,126,199,0.25);
  top: -40px; left: -40px;
  animation: orbDrift 7s ease-in-out infinite;
}
.ceo-orb-2 {
  width: 120px; height: 120px;
  background: rgba(90,157,224,0.18);
  bottom: -30px; right: -30px;
  animation: orbDrift 9s ease-in-out infinite 2s reverse;
}
.ceo-orb-3 {
  width: 80px; height: 80px;
  background: rgba(212,168,67,0.12);
  top: 50%; right: -20px;
  animation: orbDrift 6s ease-in-out infinite 4s;
}
@keyframes orbDrift {
  0%, 100% { transform: translate(0,0) scale(1); }
  33% { transform: translate(12px,-18px) scale(1.1); }
  66% { transform: translate(-10px, 12px) scale(0.92); }
}
/* CEO spotlight sweep */
.ceo-spotlight {
  position: absolute;
  inset: 0;
  background: conic-gradient(from 0deg at 50% 50%, transparent 0deg, rgba(90,157,224,0.08) 30deg, transparent 60deg);
  animation: spotlightRotate 8s linear infinite;
  pointer-events: none;
  z-index: 1;
  border-radius: inherit;
}
@keyframes spotlightRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
/* CEO badge */
.ceo-badge-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  justify-content: center;
  margin-top: 16px;
  background: rgba(61,126,199,0.08);
  border: 1px solid rgba(61,126,199,0.2);
  border-radius: 50px;
  padding: 8px 20px;
  width: fit-content;
  margin-inline: auto;
}
.ceo-live-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #27ae60;
  animation: livePulse 1.5s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes livePulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(39,174,96,0.5); }
  50% { box-shadow: 0 0 0 6px rgba(39,174,96,0); }
}
.ceo-live-text {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--blue-lighter);
}
.ceo-role {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--blue-light);
  margin-bottom: 16px;
  letter-spacing: 0.5px;
  text-align: center;
  width: 100%;
}
.ceo-values {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 40px;
  width: 100%;
}
.ceo-value {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
  padding: 24px 16px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  transition: transform var(--transition-fast), background 0.2s ease, border-color 0.2s ease;
}
.ceo-value:hover {
  transform: translateY(-4px);
  background: rgba(61,126,199,0.08);
  border-color: rgba(61,126,199,0.25);
}
.value-icon {
  width: 52px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(61,126,199,0.1);
  border: 1px solid rgba(61,126,199,0.2);
  flex-shrink: 0;
  transition: all var(--transition-fast);
  border-radius: 14px;
}
.ceo-value:hover .value-icon {
  background: rgba(61,126,199,0.2);
  border-color: rgba(61,126,199,0.4);
  box-shadow: 0 0 16px rgba(61,126,199,0.25);
}
.ceo-value h4 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 4px;
  color: var(--white);
}
.ceo-value p {
  font-size: 0.85rem;
  color: var(--gray);
  line-height: 1.5;
  margin: 0;
}

/* ===== SERVICES ===== */
#services {
  background: var(--navy-2);
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  display: flex;
  align-items: center;
}
#services > .section {
  width: 100%;
  padding-top: clamp(80px, 10vh, 110px);
  padding-bottom: clamp(60px, 8vh, 90px);
  box-sizing: border-box;
}
.services-header { margin-bottom: clamp(24px, 4vh, 48px); }
.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: clamp(12px, 1.5vw, 20px);
}
.service-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.16);
  padding: clamp(20px, 2.5vh, 36px) clamp(16px, 1.5vw, 24px);
  transition: border-color var(--transition-medium), box-shadow var(--transition-medium);
  position: relative;
  overflow: hidden;
  border-radius: 18px;
  backdrop-filter: blur(18px) saturate(1.5);
  -webkit-backdrop-filter: blur(18px) saturate(1.5);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.1), 0 8px 32px rgba(0,0,0,0.28);
}
.service-card:nth-child(1) { animation-delay: 0s; }
.service-card:nth-child(2) { animation-delay: 0.8s; }
.service-card:nth-child(3) { animation-delay: 1.6s; }
.service-card:nth-child(4) { animation-delay: 2.4s; }
@keyframes floatCard {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
}
.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--blue), var(--blue-light), var(--white));
  transform: scaleX(0);
  transition: transform 0.5s var(--ease-premium);
  transform-origin: left;
}
.service-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at top center, rgba(255,255,255,0.03) 0%, transparent 60%);
  opacity: 0;
  transition: opacity var(--transition-medium);
}
.service-card:hover::before { transform: scaleX(1); }
.service-card:hover::after { opacity: 1; }
.service-card:hover {
  transform: translateY(-10px);
  border-color: rgba(255,255,255,0.12);
  box-shadow: 0 25px 50px rgba(0,0,0,0.4), 0 0 40px rgba(61,126,199,0.08);
}
.service-card .service-icon {
  transition: transform var(--transition-medium);
}
.service-card:hover .service-icon {
  transform: scale(1.15) translateY(-4px);
}
.service-num {
  font-family: var(--font-heading);
  font-size: 3rem;
  font-weight: 700;
  color: rgba(61,126,199,0.06);
  position: absolute;
  top: 15px;
  right: 20px;
}
.service-icon { margin-bottom: 24px; }
.service-card h3 {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  margin-bottom: 12px;
}
.service-card p {
  font-size: 0.88rem;
  color: var(--gray-light);
  line-height: 1.7;
}
.service-link {
  display: inline-block;
  margin-top: 16px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--blue-light);
  transition: all 0.3s;
}
.service-link:hover { letter-spacing: 1px; }
.service-line {
  position: absolute;
  bottom: 0;
  left: 28px;
  right: 28px;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.12), transparent);
}

/* ===== TOUR CTA ===== */
#tour-cta {
  padding: 0;
  position: relative;
}
#tour-cta::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(212,168,67,0.35), transparent);
  z-index: 2;
}
#tour-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.tour-cta-inner {
  position: relative;
  padding: 120px 5%;
  text-align: center;
  overflow: visible;
}
.tour-cta-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--navy-3) 0%, rgba(61,126,199,0.08) 50%, var(--navy-3) 100%);
  border-top: 1px solid rgba(61,126,199,0.1);
  border-bottom: 1px solid rgba(61,126,199,0.1);
}
.tour-orbs {
  position: absolute;
  inset: 0;
  pointer-events: none;
  overflow: hidden;
}
.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(60px);
}
.orb-1 { width: 300px; height: 300px; background: rgba(61,126,199,0.06); top: -100px; left: 10%; animation: orbFloat 8s ease-in-out infinite; }
.orb-2 { width: 200px; height: 200px; background: rgba(90,157,224,0.05); bottom: -50px; right: 15%; animation: orbFloat 10s ease-in-out infinite 2s; }
.orb-3 { width: 150px; height: 150px; background: rgba(61,126,199,0.04); top: 30%; right: 30%; animation: orbFloat 7s ease-in-out infinite 4s; }
@keyframes orbFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20px) scale(1.1); }
}
.tour-cta-content {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border: 1px solid rgba(255, 255, 255, 0.14);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 8px 40px rgba(0,0,0,0.35);
  border-radius: 24px;
  padding: 56px 64px;
  max-width: 860px;
  margin: 0 auto;
}

/* ===== PROJECTS ===== */
#projects {
  background: transparent;
  position: relative;
}
#projects-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.project-showcase {
  display: grid;
  grid-template-columns: 1.3fr 0.7fr;
  gap: 40px;
  margin-top: 40px;
}
.project-main {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.25);
  padding: 48px 48px 72px;
  position: relative;
  overflow: hidden;
  transition: all var(--transition-medium);
  border-radius: 18px;
}
.project-main:hover {
  border-color: rgba(255,255,255,0.1);
  box-shadow: 0 20px 50px rgba(0,0,0,0.3);
}
.project-badge {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--white);
  background: linear-gradient(135deg, var(--blue), var(--blue-dark));
  padding: 6px 16px;
  margin-bottom: 20px;
  border-radius: 6px;
}
.project-location {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 1rem;
  color: var(--blue-light);
  margin-bottom: 16px;
}
.project-desc {
  font-size: 1.05rem;
  color: var(--gray-light);
  line-height: 1.8;
  margin-bottom: 24px;
}
.project-plots {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10px;
  margin-bottom: 30px;
}
.plot-card {
  position: relative;
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  display: block;
  height: 200px;
  border: 1px solid rgba(61,126,199,0.15);
  transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.35s, border-color 0.3s;
}
.plot-card:hover {
  transform: translateY(-10px) scale(1.05);
  border-color: var(--blue-light);
  box-shadow: 0 24px 48px rgba(0,0,0,0.55), 0 0 30px rgba(61,126,199,0.25);
}
.plot-card-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  transition: transform 0.6s ease;
}
.plot-card:hover .plot-card-img { transform: scale(1.12); }
.plot-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(7,14,26,0.96) 0%, rgba(7,14,26,0.5) 45%, rgba(7,14,26,0.1) 100%);
  transition: background 0.3s;
}
.plot-card:hover .plot-card-overlay {
  background: linear-gradient(to top, rgba(7,14,26,0.97) 0%, rgba(61,126,199,0.25) 50%, rgba(7,14,26,0.1) 100%);
}
/* top badge */
.plot-card-badge {
  display: inline-block;
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #ff6b35;
  background: rgba(255,107,53,0.2);
  border: 1px solid rgba(255,107,53,0.6);
  padding: 3px 8px;
  border-radius: 20px;
  align-self: flex-start;
}
.plot-card-main {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.plot-card-body {
  position: absolute;
  inset: 0;
  padding: 10px 12px 12px;
  text-align: center;
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
}
.plot-card-num {
  display: block;
  font-family: var(--font-heading);
  font-size: 3rem;
  font-weight: 700;
  line-height: 1;
  background: linear-gradient(135deg, var(--white), var(--blue-lighter));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  transition: transform 0.3s;
}
.plot-card:hover .plot-card-num { transform: scale(1.08); }
.plot-card-unit {
  display: block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.8);
  margin-top: 2px;
}
.plot-card-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--blue-light);
  margin-top: 10px;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.3s, transform 0.3s;
  border-top: 1px solid rgba(61,126,199,0.25);
  padding-top: 8px;
}
.plot-card:hover .plot-card-cta { opacity: 1; transform: translateY(0); }
/* Amenities header upgrade */
.amenities-header {
  text-align: center;
  margin-bottom: 20px;
}
.amenities-label {
  display: block;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--blue-light);
  margin-bottom: 6px;
}
.amenities-header h3 {
  font-family: var(--font-heading);
  font-size: 1.7rem;
  font-weight: 700;
  background: linear-gradient(135deg, var(--white), var(--blue-lighter));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 0 0 10px;
}
.amenities-accent {
  width: 36px;
  height: 2px;
  background: linear-gradient(90deg, var(--blue), var(--blue-light));
  margin: 0 auto;
  border-radius: 2px;
}
.project-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.project-actions .btn { padding: 14px 28px; font-size: 0.78rem; }
.project-amenities {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.25);
  padding: 36px;
  transition: border-color var(--transition-medium);
  border-radius: 18px;
}
.project-amenities:hover {
  border-color: rgba(255,255,255,0.1);
}
.project-amenities h3 {
  font-family: var(--font-heading);
  font-size: 1.2rem;
  margin-bottom: 24px;
  text-align: center;
}
.amenities-grid-mini {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}
.amenity-mini {
  background: rgba(17,30,52,0.5);
  border: 1px solid rgba(90,157,224,0.12);
  padding: 12px 8px 10px;
  text-align: center;
  transition: all var(--transition-fast);
  border-radius: 12px;
  backdrop-filter: blur(10px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}
.amenity-mini:hover {
  border-color: rgba(90,157,224,0.35);
  transform: translateY(-6px) scale(1.05);
  background: rgba(61,126,199,0.1);
  box-shadow: 0 12px 28px rgba(0,0,0,0.25), 0 0 20px rgba(61,126,199,0.1);
}
.ami {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: rgba(61,126,199,0.1);
  border-radius: 10px;
  border: 1px solid rgba(90,157,224,0.15);
  margin: 0 auto;
  transition: all var(--transition-fast);
}
.amenity-mini:hover .ami {
  background: rgba(61,126,199,0.2);
  box-shadow: 0 0 16px rgba(90,157,224,0.25);
  transform: scale(1.08);
}
.amenity-mini span:last-child {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.5px;
  color: var(--gray-light);
}

/* ===== BLOCKS ===== */
#blocks {
  background: linear-gradient(180deg, var(--navy-2) 0%, var(--navy-3) 100%);
  position: relative;
  height: 100vh;
  min-height: 100vh;
  overflow: visible;
}
#blocks > .section {
  padding-top: 130px;
  padding-bottom: 130px;
}
#blocks::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.2), transparent);
}

/* ── Blocks header ── */
.blocks-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  margin-bottom: 40px;
  text-align: center;
}
.blocks-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 40px;
  width: 100%;
}
.blocks-title-row .section-title {
  white-space: nowrap;
  flex-shrink: 0;
  text-align: left !important;
  margin: 0 !important;
  font-size: clamp(1.4rem, 2.5vw, 2.4rem) !important;
}
.blocks-title-row .section-desc {
  text-align: left !important;
  margin: 0 !important;
  max-width: none !important;
  flex: 1;
}
.blocks-heading-wrap {
  flex: 0 0 auto;
}
.blocks-heading-wrap .section-title {
  white-space: nowrap;
  margin-bottom: 8px !important;
  text-align: left !important;
}
.blocks-heading-wrap .accent-line {
  margin: 0 !important;
}
.blocks-desc {
  flex: 1;
  font-size: 1.02rem;
  color: var(--gray-light);
  line-height: 1.9;
  text-align: left;
  margin: 0;
}

/* ── Content: block grid (left) + plot sizes (right) ── */
.blocks-content {
  display: flex;
  flex-direction: row;
  gap: 24px;
  align-items: stretch;
}

/* Glass wrapper boxes */
.blocks-glass-box {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.18);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  border-radius: 20px;
  padding: 24px;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 8px 32px rgba(0,0,0,0.28);
  flex: 1;
  display: flex;
  flex-direction: column;
}
.blocks-sizes-box {
  flex: 0 0 220px;
}
.blocks-grid {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: 1fr;
  gap: 12px;
  margin-bottom: 0;
}

/* ── Block cards ── */
.block-card {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.22);
  padding: 16px 20px;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
  position: relative;
  border-radius: 16px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 4px 20px rgba(0,0,0,0.28);
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
}
.block-card:hover {
  transform: translateY(-4px);
  border-color: rgba(61,126,199,0.45);
  box-shadow: 0 12px 32px rgba(61,126,199,0.18), inset 0 1px 0 rgba(255,255,255,0.12);
}
.block-card.featured {
  background: rgba(61,126,199,0.12);
  border-color: rgba(61,126,199,0.38);
}
.block-glow {
  display: none;
}
.block-name {
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 600;
  color: var(--white);
  letter-spacing: 0.02em;
}
.block-card:hover .block-name { color: var(--blue-lighter); }
.block-status {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
}
.block-status.available { color: #2ecc71; }

/* ── Plot Sizes panel (right column, stretches to same height as grid) ── */
.blocks-sizes {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0;
  border: none;
}
.size-tags {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-template-rows: repeat(2, 1fr);
  gap: 12px;
  flex: 1;
  width: 100%;
  height: 100%;
}
.size-tag {
  background: rgba(255,255,255,0.08) !important;
  border: 1px solid rgba(255,255,255,0.22) !important;
  backdrop-filter: blur(8px) !important;
  -webkit-backdrop-filter: blur(8px) !important;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 4px 20px rgba(0,0,0,0.28) !important;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
  border-radius: 16px;
}
.size-tag:hover {
  transform: translateY(-4px);
  border-color: rgba(61,126,199,0.45) !important;
  box-shadow: 0 12px 32px rgba(61,126,199,0.18) !important;
}
.size-val {
  font-family: var(--font-heading);
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1;
}
.size-unit {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #2ecc71;
}

/* ===== ADVANCED SECTION ANIMATIONS ===== */

/* Services: 3D perspective context */
#services .services-grid { perspective: 1400px; }

/* Service icon orbital ring */
.service-icon {
  position: relative;
  width: 72px;
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  background: rgba(61,126,199,0.08);
  border-radius: 18px;
  border: 1px solid rgba(90,157,224,0.15);
}
.service-icon::after {
  content: '';
  position: absolute;
  inset: -6px;
  border-radius: 24px;
  border: 1.5px solid transparent;
  border-top-color: rgba(90,157,224,0.7);
  border-right-color: rgba(90,157,224,0.25);
  animation: iconOrbit 2.5s linear infinite;
}
.service-card:nth-child(2) .service-icon::after { animation-duration: 3.2s; }
.service-card:nth-child(3) .service-icon::after { animation-duration: 2.8s; animation-direction: reverse; }
.service-card:nth-child(4) .service-icon::after { animation-duration: 3.6s; }
@keyframes iconOrbit { to { transform: rotate(360deg); } }
.service-card { transform-style: preserve-3d; will-change: transform; }

/* Payment holographic spinning border */
@property --border-angle {
  syntax: '<angle>';
  initial-value: 0deg;
  inherits: false;
}
.payment-card.highlight {
  --border-angle: 0deg;
  background:
    linear-gradient(145deg, var(--navy-3), var(--navy-4)) padding-box,
    conic-gradient(
      from var(--border-angle),
      rgba(61,126,199,0.9) 0%,
      rgba(90,157,224,1) 20%,
      rgba(212,168,67,0.85) 40%,
      rgba(255,255,255,0.5) 55%,
      rgba(61,126,199,0.9) 70%,
      rgba(90,157,224,1) 85%,
      rgba(61,126,199,0.9) 100%
    ) border-box;
  border: 2px solid transparent !important;
  animation: spinBorder 4s linear infinite, floatCard 4s ease-in-out infinite;
  box-shadow: 0 0 40px rgba(61,126,199,0.15), 0 0 80px rgba(61,126,199,0.06), 0 20px 60px rgba(0,0,0,0.4);
}
@keyframes spinBorder { to { --border-angle: 360deg; } }

/* Payment shimmer sweep */
.payment-card-shine {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    105deg,
    transparent 20%,
    rgba(255,255,255,0.04) 38%,
    rgba(255,255,255,0.10) 50%,
    rgba(255,255,255,0.04) 62%,
    transparent 80%
  );
  background-size: 200% 100%;
  animation: payShimmer 3s ease-in-out infinite;
  pointer-events: none;
  z-index: 1;
  border-radius: inherit;
}
@keyframes payShimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* Payment feature items — start hidden, JS reveals */
.payment-features li {
  opacity: 0;
  transform: translateX(-28px);
  transition: opacity 0.45s ease, transform 0.45s cubic-bezier(0.34,1.56,0.64,1);
}
.payment-features li.pay-visible {
  opacity: 1;
  transform: translateX(0);
}

/* Project section 3D */
.project-showcase { perspective: 1200px; }
.project-main { transform-style: preserve-3d; }

/* LDA badge glow pulse */
.project-badge {
  animation: ldaGlow 2s ease-in-out infinite;
}
@keyframes ldaGlow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(61,126,199,0.5), 0 0 10px rgba(61,126,199,0.2); }
  50% { box-shadow: 0 0 0 8px rgba(61,126,199,0), 0 0 20px rgba(61,126,199,0.4); }
}

/* Plot tags start hidden */
.plot-tag {
  transform: scale(0) translateY(10px);
  opacity: 0;
  transition: transform 0.5s cubic-bezier(0.34,1.56,0.64,1), opacity 0.3s ease;
  display: inline-block;
}
.plot-tag.pt-visible {
  transform: scale(1) translateY(0);
  opacity: 1;
}

/* ===== PAYMENT ===== */
#payment-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
#payment {
  background: transparent;
  position: relative;
  overflow: hidden;
  height: 100vh;
  min-height: 100vh;
  max-height: 100vh;
  display: flex;
  align-items: center;
}
#payment > .section {
  width: 100%;
  padding-top: clamp(52px, 7vh, 80px) !important;
  padding-bottom: clamp(52px, 7vh, 80px) !important;
  box-sizing: border-box;
}
.payment-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(20px, 3vw, 48px);
  align-items: stretch;
}
.payment-highlights {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  margin-top: 36px;
  width: 100%;
}
.payment-highlight-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  text-align: left;
  gap: 14px;
  padding: 16px 18px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 14px;
  backdrop-filter: blur(12px) saturate(1.4);
  -webkit-backdrop-filter: blur(12px) saturate(1.4);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.1), 0 4px 16px rgba(0,0,0,0.2);
  transition: border-color 0.2s ease, background 0.2s ease;
}
.payment-highlight-item:hover {
  background: rgba(61,126,199,0.08);
  border-color: rgba(61,126,199,0.25);
}
.payment-highlight-icon {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(61,126,199,0.12);
  border: 1px solid rgba(61,126,199,0.25);
  border-radius: 12px;
}
.payment-highlight-item > div:last-child {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 3px;
}
.payment-highlight-item strong {
  font-family: var(--font-heading);
  font-size: clamp(0.88rem, 1.3vh, 1rem);
  font-weight: 600;
  color: var(--white);
  text-align: left;
}
.payment-highlight-item span {
  font-size: clamp(0.72rem, 1.1vh, 0.82rem);
  color: var(--gray);
  line-height: 1.4;
  text-align: left;
}
.payment-card-wrap { display: flex; justify-content: center; align-items: stretch; }
.payment-card {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.25);
  padding: clamp(18px, 2.8vh, 36px);
  transition: all var(--transition-medium);
  width: 100%;
  max-width: 480px;
  position: relative;
  overflow: hidden;
  border-radius: 20px;
}
.payment-card.highlight { border-color: rgba(61,126,199,0.3); }
.payment-card-shine {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--blue), var(--blue-light), var(--blue));
}
.payment-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 50px rgba(0,0,0,0.35), 0 0 30px rgba(61,126,199,0.06);
  border-color: rgba(255,255,255,0.12);
}
.payment-card-header { margin-bottom: clamp(12px, 1.8vh, 24px); }
.payment-tag {
  display: inline-block;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--white);
  background: linear-gradient(135deg, var(--blue), var(--blue-dark));
  padding: 4px 12px;
  margin-bottom: clamp(8px, 1.2vh, 14px);
  border-radius: 6px;
}
.payment-card h3 {
  font-family: var(--font-heading);
  font-size: clamp(1.3rem, 2.4vh, 1.8rem);
}
.payment-sub {
  font-size: 0.82rem;
  color: var(--gray);
  margin-top: 4px;
}
.payment-features {
  list-style: none;
  margin-bottom: clamp(14px, 2vh, 28px);
}
.payment-features li {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: clamp(0.78rem, 1.3vh, 0.92rem);
  padding: clamp(6px, 1vh, 10px) 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

/* ===== CONTACT ===== */
#contact-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
#contact {
  background: transparent;
  position: relative;
}
#contact::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(212,168,67,0.2), rgba(61,126,199,0.3), transparent);
}
.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: stretch;
}
.contact-details {
  margin-top: 40px;
  display: flex;
  justify-content: flex-start;
  gap: 24px;
  flex-wrap: wrap;
}
.contact-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  margin-bottom: 28px;
  text-align: center;
}
.contact-icon {
  width: 58px;
  height: 58px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  flex-shrink: 0;
  transition: all var(--transition-fast);
  border-radius: 14px;
}
.contact-icon svg {
  width: 28px !important;
  height: 28px !important;
}
.contact-item:hover .contact-icon {
  background: rgba(61,126,199,0.12);
  border-color: rgba(61,126,199,0.3);
  transform: scale(1.1);
}
.contact-item h4 {
  font-size: 1rem;
  font-weight: 600;
  margin-bottom: 2px;
  text-align: center;
}
.contact-item p {
  font-size: 1.05rem;
  color: var(--gray-light);
  line-height: 1.6;
  text-align: center;
}
.contact-item a { color: rgba(255,255,255,0.8); transition: all var(--transition-fast); }
.contact-item a:hover { color: var(--white); text-shadow: 0 0 8px rgba(255,255,255,0.15); }
.contact-chips {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-top: 28px;
  width: 100%;
  justify-items: center;
}
.contact-chip:nth-child(4),
.contact-chip:nth-child(5) {
  width: 100%;
}
.contact-chips:has(.contact-chip:nth-child(4):last-child),
.contact-chips:has(.contact-chip:nth-child(5):last-child) {
  grid-template-columns: repeat(3, 1fr);
}
.contact-chip:nth-child(4) { grid-column: 1; }
.contact-chip:nth-child(5) { grid-column: 2; }
.contact-chip {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 10px;
  padding: 16px 10px 14px;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 16px;
  backdrop-filter: blur(14px) saturate(1.5);
  -webkit-backdrop-filter: blur(14px) saturate(1.5);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 4px 20px rgba(0,0,0,0.28);
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
  text-decoration: none;
  color: inherit;
}
.contact-chip:hover {
  transform: translateY(-4px);
  border-color: rgba(61,126,199,0.45);
  box-shadow: 0 10px 28px rgba(61,126,199,0.2), inset 0 1px 0 rgba(255,255,255,0.14);
}
.chip-icon {
  width: 40px;
  height: 40px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(61,126,199,0.12);
  border: 1px solid rgba(61,126,199,0.25);
  border-radius: 12px;
}
.chip-body {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 0;
}
.chip-title {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--blue-light);
  white-space: nowrap;
}
.chip-text {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.72);
  line-height: 1.5;
  word-break: break-word;
}
.chip-text a {
  color: rgba(255,255,255,0.72);
  text-decoration: none;
  transition: color 0.2s ease;
}
.chip-text a:hover { color: var(--white); }
.contact-form-wrap {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: 48px;
  transition: border-color var(--transition-medium);
  border-radius: 20px;
}
.contact-form-wrap:hover {
  border-color: rgba(255,255,255,0.1);
}
.contact-form h3 {
  font-family: var(--font-heading);
  font-size: 1.7rem;
  margin-bottom: 28px;
}
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}
.form-group { margin-bottom: 18px; }
.form-label {
  display: block;
  font-size: 0.74rem;
  font-weight: 600;
  letter-spacing: 1.2px;
  text-transform: uppercase;
  color: rgba(184, 200, 216, 0.9);
  margin-bottom: 8px;
}
.form-honeypot {
  position: absolute;
  left: -10000px;
  width: 1px;
  height: 1px;
  overflow: hidden;
}
.form-group input,
.form-group select,
.form-group textarea {
  width: 100%;
  padding: 14px 18px;
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--white);
  background: var(--navy);
  border: 1px solid rgba(255,255,255,0.08);
  outline: none;
  transition: all var(--transition-fast);
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: rgba(255,255,255,0.3);
  box-shadow: 0 0 0 3px rgba(255,255,255,0.05);
  background: rgba(255,255,255,0.02);
}
.form-group input:hover,
.form-group select:hover,
.form-group textarea:hover {
  border-color: rgba(255,255,255,0.15);
}
.form-group select { cursor: pointer; }
.form-group select option { background: var(--navy-3); }
.form-group textarea { resize: vertical; }
.form-status {
  min-height: 1.2em;
  margin: 4px 0 12px;
  font-size: 0.84rem;
  color: rgba(184, 200, 216, 0.88);
}
.form-status.is-success { color: #9bf1bd; }
.form-status.is-error { color: #ffc0c0; }
.contact-submit {
  width: 100%;
  justify-content: center;
}
.contact-submit[disabled] {
  cursor: wait;
  opacity: 0.75;
}

/* ===== FOOTER ===== */
#footer {
  position: relative;
  background: var(--navy);
  border-top: 1px solid rgba(61,126,199,0.08);
}
.footer-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 42px 5% 30px;
}
.footer-top {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: 50px;
  margin-bottom: 40px;
}
.footer-logo-img {
  width: clamp(110px, 12vw, 150px);
  height: auto;
  margin-bottom: 16px;
  border-radius: 6px;
  padding: 4px 8px;
}
.footer-brand p {
  font-size: 0.88rem;
  color: var(--gray);
  line-height: 1.7;
}
.footer-links h4 {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.85);
  margin-bottom: 20px;
}
.footer-links a {
  display: block;
  font-size: 0.88rem;
  color: rgba(255,255,255,0.55);
  padding: 5px 0;
  transition: all var(--transition-fast);
}
.footer-links a:hover {
  color: var(--white);
  transform: translateX(4px);
}
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 30px;
  border-top: 1px solid rgba(61,126,199,0.06);
  font-size: 0.8rem;
  color: var(--gray);
}

/* ===== WHATSAPP FLOAT ===== */
.whatsapp-float {
  position: fixed;
  bottom: max(18px, calc(env(safe-area-inset-bottom) + 14px));
  right: max(18px, calc(env(safe-area-inset-right) + 14px));
  z-index: 999;
  width: 60px;
  height: 60px;
  background: #25D366;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 20px rgba(37,211,102,0.4);
  transition: bottom 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease, opacity 0.3s ease;
  animation: whatsappPulse 2s infinite;
}
.whatsapp-float:hover {
  transform: scale(1.1);
  box-shadow: 0 8px 30px rgba(37,211,102,0.5);
}
body.footer-in-view .whatsapp-float {
  bottom: max(94px, calc(env(safe-area-inset-bottom) + 80px));
  transform: none;
}
body.footer-in-view .whatsapp-float:hover {
  transform: scale(1.08);
}
@keyframes whatsappPulse {
  0%, 100% { box-shadow: 0 6px 20px rgba(37,211,102,0.4); }
  50% { box-shadow: 0 6px 30px rgba(37,211,102,0.6), 0 0 0 10px rgba(37,211,102,0.1); }
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .services-grid { grid-template-columns: repeat(2, 1fr) !important; }
  .blocks-grid { grid-template-columns: repeat(4, 1fr); }
  .payment-layout { grid-template-columns: 1fr !important; }
  .footer-top { grid-template-columns: 1fr 1fr; }
  .project-showcase { grid-template-columns: 1fr; }
  .ceo-grid { grid-template-columns: 1fr; }
  .ceo-visual { order: -1; }
  .blocks-header { gap: 32px; }
  /* Unlock fixed-height sections on tablet */
  #payment, #testimonials, #blocks {
    height: auto !important;
    min-height: unset !important;
    max-height: none !important;
    overflow: visible !important;
    display: block !important;
  }
  #ceo { padding-top: 80px !important; padding-bottom: 80px !important; }
}
@media (max-width: 768px) {
  /* Global */
  *, *::before, *::after { box-sizing: border-box; }
  body, html { overflow-x: hidden; max-width: 100%; }
  .section { padding: 56px 16px 60px; }

  /* Unlock ALL fixed-height sections */
  #hero { justify-content: center; padding: 0; min-height: 100svh; overflow: hidden; }
  #about, #ceo, #projects, #contact, #payment, #testimonials, #blocks, #services {
    height: auto !important; min-height: unset !important; max-height: none !important;
    overflow: visible !important; display: block !important;
  }
  #ceo { padding-top: 60px !important; padding-bottom: 60px !important; }
  #blocks { height: auto !important; }
  #blocks > .section { padding-top: 60px !important; padding-bottom: 60px !important; }

  /* Navbar */
  .nav-inner { justify-content: space-between; width: calc(100% - 32px); }
  .hamburger { display: flex; z-index: 10001; }
  .nav-links {
    display: none;
    position: fixed; inset: 0;
    width: 100%; height: 100dvh;
    flex-direction: column; justify-content: center; align-items: center; gap: 8px;
    background: rgba(5,10,20,0.97);
    backdrop-filter: blur(24px) saturate(1.4);
    z-index: 10000; padding: 40px 24px;
    border: none !important; border-radius: 0 !important; box-shadow: none !important;
  }
  .nav-links.open { display: flex; }
  .nav-links a {
    padding: 16px 32px !important; border-radius: 12px !important;
    font-size: 1rem !important; letter-spacing: 2px !important;
    color: rgba(255,255,255,0.85) !important; text-align: center !important;
    width: 100% !important; max-width: 280px !important;
    border: none !important; background: transparent !important;
    backdrop-filter: none !important; box-shadow: none !important;
  }
  .nav-links a:hover, .nav-links a:active { background: rgba(255,255,255,0.08) !important; color: #fff !important; }
  .nav-links .nav-tour-btn.btn {
    width: 100% !important; max-width: 280px !important;
    justify-content: center !important; margin-top: 16px !important;
    height: 48px !important; font-size: 0.85rem !important;
  }
  .hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.active span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Hero */
  .hero-content {
    padding: max(72px, 9vh) 16px max(50px, 6vh);
  }
  .hero-badge {
    font-size: 0.42rem;
    letter-spacing: 0.6px;
    padding: 5px 10px;
    gap: 6px;
    max-width: calc(100vw - 32px);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-bottom: max(10px, 1.5vh);
  }
  .hero-title {
    font-size: clamp(1.6rem, 6.5vw, 2.4rem) !important;
    margin-bottom: max(8px, 1.2vh);
    line-height: 1.15 !important;
  }
  .hero-desc {
    font-size: 0.82rem !important;
    max-width: 100% !important;
    padding: 0 4px;
    margin-bottom: max(16px, 2.5vh) !important;
    line-height: 1.55 !important;
  }
  .hero-btns {
    flex-direction: row;
    gap: 8px;
    flex-wrap: nowrap;
    margin-bottom: max(16px, 2.5vh);
    width: 100%;
  }
  .hero-btns .btn {
    flex: 1;
    justify-content: center;
    text-align: center;
    font-size: clamp(0.6rem, 2.8vw, 0.76rem);
    padding: 12px 4px;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    gap: 0;
  }
  .hero-btns .btn svg { display: none; }
  .hero-btns .btn .btn-text-short { display: inline; }
  .hero-btns .btn .btn-text-full { display: none; }
  .hero-stats {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 8px;
    flex-wrap: nowrap;
    padding: 0;
    width: 100%;
  }
  .glass-stat { flex: 1; padding: max(8px, 1.2vh) 6px; min-width: 0; text-align: center; }
  .stat-num { font-size: clamp(1.1rem, 4vw, 1.4rem); }
  .stat-plus { font-size: 0.8rem; }
  .stat-label { font-size: clamp(0.42rem, 1.4vw, 0.52rem); letter-spacing: 0.2px; display: block; }
  .stat-divider { display: none; }
  .hero-marquee { height: 38px; bottom: 0; }
  .marquee-track span { font-size: 0.6rem; padding: 0 12px; }

  /* About */
  .about-grid { grid-template-columns: 1fr; gap: 24px; }
  .about-right { order: -1; display: flex !important; justify-content: center !important; align-items: center !important; width: 100%; animation: none !important; }
  .about-card { width: 100% !important; max-width: 340px !important; margin: 0 auto; }
  .about-card-inner { width: 100% !important; padding: 28px 24px !important; }
  .about-left { padding: 24px 20px !important; }
  .about-features { grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 20px; }

  /* CEO */
  .ceo-grid { grid-template-columns: 1fr; gap: 24px; }
  .ceo-visual { order: -1; }
  .ceo-frame { width: 200px !important; height: 240px !important; }
  .ceo-initials { font-size: 3rem; }
  .ceo-info { padding: 24px 20px !important; }
  .ceo-role { font-size: 0.9rem; }
  .ceo-values { grid-template-columns: 1fr !important; gap: 12px; margin-top: 24px; }
  .ceo-value { padding: 16px 14px; flex-direction: row !important; text-align: left !important; gap: 14px; align-items: center; }
  .ceo-value > div { text-align: left !important; }
  .value-icon { width: 44px !important; height: 44px !important; flex-shrink: 0; }
  .ceo-value h4 { font-size: 0.92rem; margin-bottom: 2px; }
  .ceo-value p { font-size: 0.8rem; }

  /* Services */
  #services { 
    min-height: 100vh !important; 
    height: auto !important;
    display: block !important; 
    padding: 0;
  }
  #services > .section {
    padding-top: clamp(60px, 8vh, 80px) !important;
    padding-bottom: clamp(60px, 8vh, 80px) !important;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .services-header {
    margin-bottom: clamp(24px, 4vh, 32px);
  }
  .services-grid { 
    grid-template-columns: 1fr !important; 
    gap: clamp(16px, 2.5vh, 24px);
    max-width: 100%;
  }
  .service-card { 
    padding: clamp(20px, 3vh, 28px) clamp(16px, 2.5vw, 20px);
    margin: 0 auto;
    max-width: 100%;
    width: 100%;
  }
  .service-card h3 { 
    font-size: clamp(1.1rem, 2.2vh, 1.3rem);
    margin-bottom: clamp(8px, 1.5vh, 12px);
  }
  .service-card p { 
    font-size: clamp(0.82rem, 1.6vh, 0.9rem);
    line-height: 1.6;
  }
  .service-icon {
    width: clamp(48px, 6vh, 60px);
    height: clamp(48px, 6vh, 60px);
    margin-bottom: clamp(16px, 2.5vh, 20px);
  }
  .service-num {
    font-size: clamp(2.2rem, 4vh, 2.8rem);
    top: clamp(12px, 2vh, 16px);
    right: clamp(16px, 2.5vw, 20px);
  }

  /* Tour CTA */
  .tour-cta-inner { padding: 60px 16px !important; }
  .tour-cta-content { padding: 32px 20px !important; }

  /* Projects */
  .project-showcase { grid-template-columns: 1fr; gap: 20px; margin-top: 20px; }
  .project-main { padding: 22px 18px 28px !important; }
  .project-desc { font-size: 0.86rem; }
  .project-plots { grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 18px; }
  .plot-card { height: 130px; }
  .plot-card-num { font-size: 1.8rem !important; }
  .plot-card-badge { color: #ff6b35; background: rgba(255,107,53,0.15); border-color: rgba(255,107,53,0.5); }
  .project-actions { flex-direction: column; gap: 10px; }
  .project-actions .btn { width: 100%; justify-content: center; }
  .project-amenities { padding: 20px 16px !important; }
  .amenities-grid-mini { grid-template-columns: repeat(3, 1fr); gap: 10px; }

  /* Blocks */
  .blocks-title-row { flex-direction: column; align-items: center; gap: 8px; }
  .blocks-heading-wrap .section-title { white-space: normal !important; text-align: center !important; }
  .blocks-heading-wrap .accent-line { margin: 0 auto 0 !important; }
  .blocks-title-row .section-desc { text-align: center !important; font-size: 0.84rem !important; }
  .blocks-content { flex-direction: column; gap: 14px; }
