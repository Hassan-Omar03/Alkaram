/* Shared rhythm and alignment */
.section {
  max-width: var(--container-wide);
  padding: 86px 5% 90px;
}

.section > .section-label,
.section > .section-title,
.section > .accent-line,
.section > .section-desc,
.services-header,
.testimonials-header,
.blocks-header,
.payment-info,
.contact-info {
  max-width: var(--container-medium);
  margin-left: auto;
  margin-right: auto;
}

/* CTA hierarchy: one strong primary, one quiet secondary */
