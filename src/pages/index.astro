            </span><span>Restaurants</span>
          </div>
          <div class="amenity-mini">
            <span class="ami">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            </span><span>Gated Security</span>
          </div>
          <div class="amenity-mini">
            <span class="ami">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.5"><path d="M3 3h18M3 12h18M3 21h18"/></svg>
            </span><span>Boulevards</span>
