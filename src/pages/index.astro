      for(let i=0;i<mC;i++){mP[i*3]=(Math.random()-.5)*40;mP[i*3+1]=(Math.random()-.5)*25;mP[i*3+2]=(Math.random()-.5)*30-5;mCl[i*3]=.35+Math.random()*.2;mCl[i*3+1]=.6+Math.random()*.2;mCl[i*3+2]=.88+Math.random()*.1;}
      mG.setAttribute('position',new THREE.BufferAttribute(mP,3)); mG.setAttribute('color',new THREE.BufferAttribute(mCl,3));
      pyScene.add(new THREE.Points(mG,new THREE.PointsMaterial({size:.1,vertexColors:true,transparent:true,opacity:1,sizeAttenuation:true,depthWrite:false})));
      const mkM=(c:number,o:number)=>new THREE.MeshBasicMaterial({color:c,wireframe:true,transparent:true,opacity:o});
      [[new THREE.TorusGeometry(1.4,.25,14,48),[-8,2,-6],mkM(0x5a9de0,.14)],[new THREE.IcosahedronGeometry(1.6,1),[9,1,-9],mkM(0x5a9de0,.12)],[new THREE.TorusKnotGeometry(.8,.22,80,10),[0,-3,-12],mkM(0xd4a843,.09)]].forEach(([g,p,m]:any)=>{const mesh=new THREE.Mesh(g,m);mesh.position.set(p[0],p[1],p[2]);pyScene.add(mesh);});
      pyCam.position.set(0,0,8);
      const pyClock=new THREE.Clock(); let pyLast=0;
      const animPay=(now:number)=>{
