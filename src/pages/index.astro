</style>



<script>
import * as THREE from 'three';
import { animate, inView, stagger } from 'https://cdn.jsdelivr.net/npm/motion@11/+esm';

document.addEventListener('DOMContentLoaded', () => {
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let mouseX = 0, mouseY = 0;
  let pointerX = window.innerWidth * 0.5;
  let pointerY = window.innerHeight * 0.5;

  document.addEventListener('mousemove', (e) => {
    mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
    mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
    pointerX = e.clientX;
    pointerY = e.clientY;
  });

  // === AMBIENT CURSOR AURORA ===
  if (!prefersReducedMotion && window.innerWidth > 960) {
    const aurora = document.createElement('div');
    aurora.className = 'cursor-aurora';
    aurora.style.transition = 'transform 0.12s linear';
    document.body.appendChild(aurora);
    document.body.classList.add('aurora-active');
    document.addEventListener('mousemove', (e) => {
      aurora.style.transform = `translate3d(${e.clientX}px, ${e.clientY}px, 0) translate(-50%, -50%)`;
    });
  }

  // === CUSTOM MORPHING CURSOR ===
  if (!prefersReducedMotion && window.innerWidth > 768) {
    const dot  = document.getElementById('cursor-dot')  as HTMLElement | null;
    const ring = document.getElementById('cursor-ring') as HTMLElement | null;
    let rx = 0, ry = 0;

    document.addEventListener('mousemove', (e) => {
      if (dot)  dot.style.transform  = `translate(${e.clientX - 4}px, ${e.clientY - 4}px)`;
      // Ring trails with lerp
      rx += (e.clientX - rx) * 0.18;
      ry += (e.clientY - ry) * 0.18;
    });

    let ringLast = 0;
    const followRing = (now: number) => {
      if (now - ringLast >= 33) { // ~30fps
        ringLast = now;
        if (ring) ring.style.transform = `translate(${rx - 18}px, ${ry - 18}px)`;
      }
      requestAnimationFrame(followRing);
    };
    requestAnimationFrame(followRing);

    // Morph states
    const setBtnCursor = () => { document.body.classList.add('cursor-btn'); document.body.classList.remove('cursor-card','cursor-link'); };
    const setCardCursor = () => { document.body.classList.add('cursor-card'); document.body.classList.remove('cursor-btn','cursor-link'); };
    const setLinkCursor = () => { document.body.classList.add('cursor-link'); document.body.classList.remove('cursor-btn','cursor-card'); };
    const clearCursor  = () => { document.body.classList.remove('cursor-btn','cursor-card','cursor-link'); };

    document.querySelectorAll('.btn, button').forEach(el => {
      el.addEventListener('mouseenter', setBtnCursor);
      el.addEventListener('mouseleave', clearCursor);
    });
    document.querySelectorAll('.service-card, .testimonial-card, .block-card, .about-card, .payment-card').forEach(el => {
      el.addEventListener('mouseenter', setCardCursor);
      el.addEventListener('mouseleave', clearCursor);
    });
    document.querySelectorAll('a:not(.btn)').forEach(el => {
      el.addEventListener('mouseenter', setLinkCursor);
      el.addEventListener('mouseleave', clearCursor);
    });
  }

  // === CINEMATIC SECTION AMBIENCE ===
  const sections = document.querySelectorAll('section');
  sections.forEach((section) => section.classList.add('cinematic-section'));
  const sectionObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
      }
    });
  }, { threshold: 0, rootMargin: '0px 0px -60px 0px' });
  sections.forEach((section) => sectionObserver.observe(section));

  // === HERO LETTER REVEAL ===
  if (!prefersReducedMotion) {
    const heroLines = document.querySelectorAll('.hero-line');
    heroLines.forEach((line, lineIdx) => {
      const txt = line.textContent || '';
      line.textContent = '';
      Array.from(txt).forEach((char, charIdx) => {
        const span = document.createElement('span');
        span.className = char === ' ' ? 'char space' : 'char';
        span.textContent = char;
        span.style.setProperty('--char-delay', `${lineIdx * 180 + charIdx * 28}ms`);
        line.appendChild(span);
      });
      requestAnimationFrame(() => line.classList.add('animate-in'));
    });
  }

  // === MAGNETIC BUTTON MICRO-INTERACTIONS ===
  if (!prefersReducedMotion) {
    document.querySelectorAll('.btn').forEach((button) => {
      const el = button as HTMLElement;
      el.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = el.getBoundingClientRect();
        const x = (e.clientX - rect.left - rect.width / 2) / rect.width;
        const y = (e.clientY - rect.top - rect.height / 2) / rect.height;
        el.style.setProperty('--mag-x', `${x * 14}px`);
        el.style.setProperty('--mag-y', `${y * 12}px`);
        el.classList.add('magnetic-active');
      });
      el.addEventListener('mouseleave', () => {
        el.style.setProperty('--mag-x', '0px');
        el.style.setProperty('--mag-y', '0px');
        el.classList.remove('magnetic-active');
      });
    });
  }

  // === HERO 3D SCENE — PREMIUM NEBULA ===
  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  if (canvas) {
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2(0x070e1a, 0.018);
    const camera = new THREE.PerspectiveCamera(70, window.innerWidth / window.innerHeight, 0.1, 120);
