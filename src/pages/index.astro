/* ===== CUSTOM MORPHING CURSOR ===== */
#cursor-dot {
  position: fixed;
  top: 0; left: 0;
  width: 8px;
  height: 8px;
  background: var(--blue-light);
  border-radius: 50%;
  pointer-events: none;
  z-index: 99999;
  transform: translate(-50%, -50%);
  transition: width 0.2s ease, height 0.2s ease, background 0.2s ease, border-radius 0.2s ease;
  mix-blend-mode: screen;
}
#cursor-ring {
  position: fixed;
  top: 0; left: 0;
  width: 36px;
  height: 36px;
  border: 1.5px solid rgba(90, 157, 224, 0.55);
  border-radius: 50%;
  pointer-events: none;
  z-index: 99998;
  transform: translate(-50%, -50%);
  transition: width 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
              height 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
              border-color 0.3s ease,
              border-radius 0.3s ease,
              background 0.3s ease;
}
body.cursor-btn #cursor-dot { width: 6px; height: 6px; background: white; }
body.cursor-btn #cursor-ring { width: 56px; height: 56px; border-color: rgba(255,255,255,0.7); background: rgba(255,255,255,0.04); }
body.cursor-card #cursor-dot { width: 10px; height: 10px; background: var(--blue-lighter); }
body.cursor-card #cursor-ring { width: 50px; height: 50px; border-color: rgba(90,157,224,0.5); border-radius: 14px; background: rgba(61,126,199,0.05); }
body.cursor-link #cursor-ring { width: 44px; height: 44px; border-color: var(--gold); background: rgba(212,168,67,0.05); }
@media (max-width: 768px) { #cursor-dot, #cursor-ring { display: none; } }

/* ===================================================================
   TARGETED SECTION HEADER FIXES
   =================================================================== */

/* ── WHO WE ARE ──
   Label: text-align center
   Heading: bigger font
   Accent-line: tighter gap after heading                             */
/* ===== SECTION HEADER CONSISTENCY =====
   Every section: label centered, title centered, accent-line centered,
   desc centered. No per-section overrides needed.
===== */

.section-label {
  display: block !important;
  text-align: center !important;
  font-size: 1rem !important;
  font-weight: 600 !important;
  letter-spacing: 4px !important;
  text-transform: uppercase;
  color: var(--blue-light);
  margin-bottom: 10px;
}

.section-title {
  display: block !important;
  text-align: center !important;
  font-family: var(--font-heading);
  font-size: clamp(2.2rem, 4vw, 3.6rem) !important;
  font-weight: 600;
  line-height: 1.12;
  margin-bottom: 10px;
  color: var(--white);
}

.accent-line {
  width: 80px !important;
  height: 4px !important;
  background: linear-gradient(90deg, var(--blue), var(--blue-light)) !important;
  margin: 0 auto 28px !important;
  border-radius: 2px;
  display: block;
}

.section-desc {
  font-size: 0.98rem !important;
  color: var(--gray-light);
  line-height: 1.8;
  text-align: center !important;
  max-width: 700px;
  margin: 0 auto 40px !important;
}

/* Services title stays centered */
#services .services-header .section-title { text-align: center !important; }

/* Testimonials title centered */
#testimonials .testimonials-header .section-title { text-align: center !important; }

/* Payment title size */
#payment .section-title { font-size: clamp(2rem, 3.5vw, 3rem) !important; }

/* Contact info desc left-aligned inside the card */
#contact .contact-info .section-desc { text-align: center !important; margin-left: auto !important; margin-right: auto !important; }

/* Blocks header */
.blocks-header { align-items: center; }
#blocks .blocks-header { margin-bottom: 32px; }

/* Project actions centered */
.project-actions { justify-content: center; }

/* Amenities label */
.amenities-label {
  display: block;
  text-align: center;
  font-size: 1rem !important;
  letter-spacing: 4px;
}

/* ── ANIMATION OVERHAUL ──
   Remove slow curtain reveal; keep all text visible immediately    */
.section-title::after { display: none !important; }

/* Remove initial hidden states — text always visible */
#ceo .ceo-frame,
#ceo .ceo-role,
#ceo .ceo-value,
#ceo .value-icon,
#ceo .ceo-info .section-title,
#testimonials .testimonials-header h2,
#testimonials .testimonials-header .section-label,
#testimonials .testimonials-header .accent-line,
#testimonials .testimonial-card {
  opacity: 1 !important;
  transform: none !important;
  filter: none !important;
}

/* Fast reveal — 0.15s snap-in instead of 0.4s slow rise */
.reveal {
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 0.15s ease, transform 0.15s ease;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
/* ── FAST CSS TEXT ANIMATIONS (play immediately, no scroll delay) ── */
@keyframes hdrUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes hdrDown {
  from { opacity: 0; transform: translateY(-12px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes lineGrow {
  from { transform: scaleX(0); opacity: 0; transform-origin: left; }
  to   { transform: scaleX(1); opacity: 1; }
}
@keyframes labelShimmer {
  0%,100% { color: var(--blue-light); }
  50%     { color: var(--blue-lighter); text-shadow: 0 0 10px rgba(139,190,240,0.5); }
}
@keyframes accentShimmer {
  0%   { background-position: 0% 0%; }
  100% { background-position: 200% 0%; }
}
@keyframes accentPulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(61,126,199,0); }
  50%     { box-shadow: 0 0 6px 2px rgba(61,126,199,0.3); }
}

/* Section label: fast drop-in + periodic shimmer */
.section-label {
  animation: hdrDown 0.22s ease both, labelShimmer 3s ease 0.8s infinite;
}
/* Section title: fast rise */
.section-title  { animation: hdrUp 0.25s ease 0.05s both; }
.section-title:hover { text-shadow: 0 2px 20px rgba(255,255,255,0.1); transition: text-shadow 0.3s ease; }
/* Section desc: fast rise with slight delay */
.section-desc   { animation: hdrUp 0.25s ease 0.09s both; }
/* Accent-line: grow left-to-right + moving gradient + pulse glow */
.accent-line {
  background-size: 200% 100%;
  background-image: linear-gradient(90deg, var(--blue), var(--blue-lighter), var(--blue));
  animation: lineGrow 0.28s ease 0.07s both, accentShimmer 2.5s linear 0.5s infinite, accentPulse 3s ease 0.5s infinite;
}

/* ── ENHANCED CARD HOVER GLOWS ── */
.service-card { transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease !important; }
.service-card:hover {
  transform: translateY(-7px) !important;
  box-shadow: 0 12px 40px rgba(61,126,199,0.25), inset 0 1px 0 rgba(255,255,255,0.1) !important;
  border-color: rgba(61,126,199,0.45) !important;
}
.block-card { transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease !important; }
.block-card:hover {
  transform: translateY(-5px) !important;
  box-shadow: 0 10px 32px rgba(61,126,199,0.2) !important;
  border-color: rgba(61,126,199,0.4) !important;
}
.about-card-inner:hover {
  box-shadow: 0 8px 28px rgba(61,126,199,0.18) !important;
  border-color: rgba(61,126,199,0.3) !important;
}
/* Project main hover */
.project-main:hover {
  box-shadow: 0 8px 32px rgba(61,126,199,0.15) !important;
}

/* ================================================================
   SECTION BEAUTY ENHANCEMENTS
   ================================================================ */

/* Animated underline on section-title hover */
.section-title { position: relative; }
.section-title::before {
  content: ''; position: absolute; bottom: -2px; left: 0;
  width: 0; height: 1px;
  background: linear-gradient(90deg, var(--blue-light), transparent);
  transition: width 0.5s ease;
}
.section-title:hover::before { width: 100%; }

/* ABOUT: Float card + feature hover */
@keyframes floatCard { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
#about .about-right { animation: floatCard 5s ease-in-out infinite; }
#about .about-feature {
  border-left: 2px solid transparent; padding-left: 10px;
  transition: border-color 0.3s ease, padding-left 0.3s ease;
}
#about .about-feature:hover { border-left-color: var(--blue-light); padding-left: 14px; }
#about .about-feature:hover .feature-icon {
  transform: rotate(15deg) scale(1.15);
  background: rgba(61,126,199,0.2); box-shadow: 0 0 12px rgba(61,126,199,0.3);
}

/* CEO: Float frame */
@keyframes floatFrame { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
#ceo .ceo-frame {
  animation: floatFrame 6s ease-in-out infinite;
  border: 1px solid rgba(61,126,199,0.3) !important;
  box-shadow: 0 0 30px rgba(61,126,199,0.1), inset 0 1px 0 rgba(255,255,255,0.08) !important;
}
#ceo .ceo-value { border-radius: 16px; }
#ceo .ceo-value:hover { transform: translateY(-4px); background: rgba(61,126,199,0.08); }

/* SERVICES: Icon hover spin + card glow spot */
#services .service-card { position: relative; overflow: hidden; }
#services .service-card::after {
  content: ''; position: absolute; top: -40%; left: -40%;
  width: 80%; height: 80%;
  background: radial-gradient(circle, rgba(61,126,199,0.07), transparent 70%);
  opacity: 0; pointer-events: none; transition: opacity 0.4s ease;
}
#services .service-card:hover::after { opacity: 1; }
#services .service-icon { transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease; }
#services .service-card:hover .service-icon {
  transform: rotate(-8deg) scale(1.15); box-shadow: 0 0 18px rgba(61,126,199,0.25);
}

/* TOUR CTA: Pulse glow + btn ripple */
@keyframes ctaGlow {
  0%,100% { box-shadow: inset 0 0 60px rgba(61,126,199,0.04); }
  50%     { box-shadow: inset 0 0 100px rgba(61,126,199,0.10); }
}
#tour-cta { animation: ctaGlow 4s ease-in-out infinite; }
@keyframes btnPulse {
  0%   { box-shadow: 0 0 0 0 rgba(61,126,199,0.45); }
  70%  { box-shadow: 0 0 0 14px rgba(61,126,199,0); }
  100% { box-shadow: 0 0 0 0 rgba(61,126,199,0); }
}
.btn-tour { animation: btnPulse 2.5s ease infinite; }

/* PROJECTS: hover effects */
.plot-tag { transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1), background 0.2s ease; }
.plot-tag:hover { transform: scale(1.08); background: rgba(61,126,199,0.18); }
.amenity-mini { transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease; }
.amenity-mini:hover { transform: translateY(-4px) scale(1.05); box-shadow: 0 8px 20px rgba(61,126,199,0.2); }

/* BLOCKS: nth-child stagger + name glow */
#blocks .block-card:nth-child(1) { transition-delay: 0.00s; }
#blocks .block-card:nth-child(2) { transition-delay: 0.04s; }
#blocks .block-card:nth-child(3) { transition-delay: 0.08s; }
#blocks .block-card:nth-child(4) { transition-delay: 0.12s; }
#blocks .block-card:nth-child(5) { transition-delay: 0.16s; }
#blocks .block-card:nth-child(6) { transition-delay: 0.20s; }
#blocks .block-card:nth-child(7) { transition-delay: 0.24s; }
#blocks .block-card:nth-child(8) { transition-delay: 0.28s; }
.block-name { transition: color 0.2s ease; }
.block-card:hover .block-name { color: var(--blue-lighter); }

/* PAYMENT: Shimmer border + feature hover */
@keyframes borderSpin { 0% { background-position: 0% 50%; } 100% { background-position: 200% 50%; } }
#payment .payment-card { position: relative; }
#payment .payment-card::before {
  content: ''; position: absolute; inset: -1px; border-radius: inherit;
  background: linear-gradient(90deg, var(--blue-dark), var(--blue-light), var(--gold), var(--blue-dark));
  background-size: 200% 100%; animation: borderSpin 3s linear infinite;
  z-index: -1; opacity: 0.35;
}
#payment .payment-features li { transition: transform 0.2s ease, color 0.2s ease; cursor: default; }
#payment .payment-features li:hover { transform: translateX(6px); color: var(--white-soft); }

/* TESTIMONIALS: Top border + star twinkle */
.testimonial-card { position: relative; overflow: hidden; }
.testimonial-card::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, rgba(61,126,199,0.5), transparent);
  opacity: 0; transition: opacity 0.3s ease;
}
.testimonial-card:hover::after { opacity: 1; }
@keyframes starTwinkle {
  0%,100% { filter: drop-shadow(0 0 3px rgba(212,168,67,0.4)); }
  50%     { filter: drop-shadow(0 0 8px rgba(212,168,67,0.8)); }
}
.testimonial-stars { animation: starTwinkle 2s ease-in-out infinite; }

/* CONTACT: Input focus glow + icon hover */
.contact-form-wrap input:focus,
.contact-form-wrap textarea:focus,
.contact-form-wrap select:focus {
  outline: none;
  border-color: var(--blue-light) !important;
  box-shadow: 0 0 0 3px rgba(61,126,199,0.15) !important;
  background: rgba(61,126,199,0.04) !important;
  transition: all 0.2s ease;
}
.contact-icon { transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.3s ease; }
.contact-item:hover .contact-icon { transform: scale(1.15) rotate(-5deg); box-shadow: 0 0 16px rgba(61,126,199,0.3); }

/* WHATSAPP: opacity-only pulse (no box-shadow repaint) */
@keyframes waPulse {
  0%,100% { opacity: 1; }
  50%     { opacity: 0.72; }
}
.whatsapp-float { animation: waPulse 2s ease-in-out infinite !important; }

/* =================================================================
   PERFORMANCE: Strip expensive animations, use GPU-only replacements
   ================================================================= */

/* Accent-line: remove background-position shimmer + box-shadow pulse */
.accent-line {
  background-image: linear-gradient(90deg, var(--blue), var(--blue-lighter)) !important;
  background-size: 100% 100% !important;
  animation: lineGrow 0.28s ease 0.07s both !important;
}

/* section-label: use opacity pulse instead of color/text-shadow */
@keyframes labelPulse { 0%,100% { opacity: 0.85; } 50% { opacity: 1; } }
.section-label { animation: hdrDown 0.22s ease both, labelPulse 3s ease 0.8s infinite !important; }

/* btn-tour + tour-cta: remove box-shadow animation */
.btn-tour { animation: none !important; }
#tour-cta { animation: none !important; }

/* payment border: stop background-position animation */
#payment .payment-card::before { animation: none !important; opacity: 0.28; }

/* will-change for floating elements → GPU layer pre-promotion */
#about .about-right { will-change: transform; }
#ceo .ceo-frame     { will-change: transform; }

/* =================================================================
   SIZE TAGS: Fix readability — bright, high-contrast
   ================================================================= */
.size-val {
  color: #ffffff !important;
  font-family: var(--font-body) !important;
  font-size: 2.4rem !important;
  font-weight: 700 !important;
  opacity: 1 !important;
  display: block !important;
  line-height: 1.1 !important;
}
.size-unit {
  color: #2ecc71 !important;
  opacity: 1 !important;
  display: block !important;
  font-size: 0.78rem !important;
  letter-spacing: 2px !important;
}
/* Plot card numbers (3, 5, 10, 15 Marla, 1 Kanal) */
.plot-card-num {
  font-family: var(--font-body) !important;
  font-weight: 800 !important;
}
/* Hero stats numbers (500+, 1800+, 4+) */
.stat-num {
  font-family: var(--font-body) !important;
  font-weight: 700 !important;
}

/* ================================================================
   FIXED BACKGROUND SCROLL BEHAVIOR
   Keep one persistent backdrop visible under all main sections.
   ================================================================ */
#hero-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
