  .size-tags { grid-template-columns: repeat(4, 1fr); grid-template-rows: auto; gap: 8px; }
  .size-val { font-size: 1.6rem !important; }
  .size-unit { font-size: 0.62rem !important; }

  /* Payment */
  .payment-layout { grid-template-columns: 1fr; gap: 20px; }
  .payment-info { padding: 24px 20px !important; }
  .payment-highlights { grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 20px; }
  .payment-highlight-item { padding: 16px 12px; gap: 10px; }
  .payment-card { padding: 22px 18px !important; }

  /* Testimonials */
  #testimonials {
    height: auto !important;
    min-height: unset !important;
    max-height: none !important;
    overflow: visible !important;
    display: block !important;
  }
  #testimonials > .section {
    padding-top: 44px !important;
    padding-bottom: 44px !important;
  }
  .testimonials-header { margin-bottom: 20px !important; }
  .testimonials-header h2 { font-size: 1.5rem !important; }
