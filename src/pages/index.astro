---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Al Karam Real Estate | Authorized Sub-Dealer of Al Jalil Developers, Lahore">

<!-- Scroll progress bar -->
<div id="scroll-progress"></div>



<!-- ==================== NAVBAR ==================== -->
<nav id="navbar">
  <div class="nav-inner">
    <a href="#hero" class="nav-logo">
      <img src="/images/logo.png" alt="Al Karam Real Estate" class="nav-logo-img" loading="eager" decoding="async" />
    </a>
    <div class="nav-links" id="navLinks">
      <a href="#about">About</a>
      <a href="#ceo">Leadership</a>
      <a href="#services">Services</a>
      <a href="#projects">Projects</a>
      <a href="#blocks">Blocks</a>
      <a href="#payment">Payment</a>
      <a href="#contact">Contact</a>
      <a href="http://myajdcloud.com/vtour/ajg.html" target="_blank" class="btn btn-primary nav-tour-btn">360° Tour</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- ==================== HERO ==================== -->
<section id="hero">
  <canvas id="hero-canvas"></canvas>
  <div class="hero-overlay"></div>
  <div class="hero-particles-overlay"></div>
  <div class="hero-content">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      AUTHORIZED SUB-DEALER OF AL JALIL DEVELOPERS
    </div>
    <h1 class="hero-title">
      <span class="hero-line">Building Dreams.</span>
      <span class="hero-line accent">Delivering Trust.</span>
    </h1>
    <p class="hero-desc">Your premier gateway to luxury living in Al Jalil Garden Housing Scheme — Lahore's most prestigious gated community development.</p>
    <div class="hero-btns">
      <a href="http://myajdcloud.com/vtour/ajg.html" target="_blank" class="btn btn-tour">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20M2 12h20"/></svg>
        <span class="btn-text-full">Explore 360° Virtual Tour</span>
        <span class="btn-text-short">360° Tour</span>
      </a>
      <a href="#contact" class="btn btn-outline">Get In Touch</a>
    </div>
    <div class="hero-stats">
      <div class="stat glass-stat">
        <span class="stat-num" data-target="500">0</span><span class="stat-plus">+</span>
        <span class="stat-label">Properties Sold</span>
      </div>
      <div class="stat glass-stat">
        <span class="stat-num" data-target="1800">0</span><span class="stat-plus">+</span>
        <span class="stat-label">Happy Clients</span>
      </div>
      <div class="stat glass-stat">
        <span class="stat-num" data-target="4">0</span><span class="stat-plus">+</span>
        <span class="stat-label">Years of Trust</span>
      </div>
    </div>
  </div>
  <div class="marquee-strip hero-marquee" aria-hidden="true">
  <div class="marquee-track">
    <span>Al Jalil Garden</span><span class="marquee-dot">✦</span>
    <span>LDA Approved</span><span class="marquee-dot">✦</span>
    <span>Authorized Sub-Dealer</span><span class="marquee-dot">✦</span>
    <span>500+ Properties Sold</span><span class="marquee-dot">✦</span>
    <span>Lahore's Premier Estate</span><span class="marquee-dot">✦</span>
    <span>360° Virtual Tour</span><span class="marquee-dot">✦</span>
    <span>Easy Installment Plans</span><span class="marquee-dot">✦</span>
    <span>Gated Community</span><span class="marquee-dot">✦</span>
    <span>Al Jalil Garden</span><span class="marquee-dot">✦</span>
    <span>LDA Approved</span><span class="marquee-dot">✦</span>
    <span>Authorized Sub-Dealer</span><span class="marquee-dot">✦</span>
    <span>500+ Properties Sold</span><span class="marquee-dot">✦</span>
    <span>Lahore's Premier Estate</span><span class="marquee-dot">✦</span>
    <span>360° Virtual Tour</span><span class="marquee-dot">✦</span>
    <span>Easy Installment Plans</span><span class="marquee-dot">✦</span>
    <span>Gated Community</span><span class="marquee-dot">✦</span>
  </div>

  <!-- ==================== MARQUEE TICKER ==================== -->
</div>

</section>

<!-- ==================== ABOUT ==================== -->
<section id="about">
  <div class="section">
    <div class="about-grid">
      <div class="about-left">
        <span class="section-label">Who We Are</span>
        <h2 class="section-title">The Biggest & Most Trusted Name in Al Jalil Garden</h2>
        <div class="accent-line"></div>
        <p class="section-desc">Al Karam Real Estate is an authorized sub-dealer of <strong>Al Jalil Developers</strong> — one of Pakistan's leading real estate and infrastructure companies. We specialize in property sales, purchases, and marketing across Lahore's most prestigious housing society.</p>
        <p class="section-desc" style="margin-top:16px;">With our office on Main Boulevard, Al Jalil Garden (2 km from Faizpur Interchange), we provide on-ground support, transparent dealings, and personalized service to every client.</p>
        <div class="about-features">
          <div class="about-feature">
            <div class="feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
            </div>
            <span>LDA Approved Projects</span>
          </div>
          <div class="about-feature">
            <div class="feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
            </div>
            <span>Transparent Dealings</span>
          </div>
          <div class="about-feature">
            <div class="feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
            </div>
            <span>On-Ground Support</span>
          </div>
          <div class="about-feature">
            <div class="feature-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="2"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
            </div>
            <span>Easy Installment Plans</span>
          </div>
        </div>
      </div>
      <div class="about-right">
        <div class="about-card">
          <div class="about-card-inner">
            <img src="/images/logo.png" alt="Al Karam Real Estate" class="about-logo-img" loading="lazy" decoding="async" />
            <div class="card-divider"></div>
            <div class="card-parent">
              <span class="card-parent-label">Partnered With</span>
              <span class="card-parent-name">Al Jalil Developers</span>
            </div>
          </div>
          <div class="about-card-glow"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== CEO ==================== -->
<section id="ceo">
  <canvas id="ceo-canvas"></canvas>
  <div class="section">
    <div class="ceo-grid">
      <div class="ceo-visual">
        <div class="ceo-frame">
          <div class="ceo-orb ceo-orb-1"></div>
          <div class="ceo-orb ceo-orb-2"></div>
          <div class="ceo-orb ceo-orb-3"></div>
          <div class="ceo-initials">SZG</div>
          <div class="ceo-frame-border"></div>
          <div class="ceo-spotlight"></div>
        </div>
      </div>
      <div class="ceo-info">
        <span class="section-label">Leadership</span>
        <h2 class="section-title ceo-name-heading">Sheikh Zaheer Ghazanfar</h2>
        <div class="accent-line"></div>
        <p class="ceo-role">Chief Executive Officer — Al Karam Real Estate</p>
        <p class="section-desc">Under the visionary leadership of Sheikh Zaheer Ghazanfar, Al Karam Real Estate has grown to become the biggest and most trusted real estate partner in Al Jalil Garden Housing Scheme. His commitment to transparency, customer satisfaction, and ethical business practices has established Al Karam as the go-to name for property investment in Lahore.</p>
        <div class="ceo-values">
          <div class="ceo-value">
            <div class="value-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <div>
              <h4>Integrity First</h4>
              <p>Every transaction built on trust and transparency</p>
            </div>
          </div>
          <div class="ceo-value">
            <div class="value-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <div>
              <h4>Client-Centric</h4>
              <p>Personalized service for every client, every time</p>
            </div>
          </div>
          <div class="ceo-value">
            <div class="value-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <div>
              <h4>Results Driven</h4>
              <p>500+ properties sold with 100% client satisfaction</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== SERVICES ==================== -->
<section id="services">
  <div class="section">
    <div class="services-header">
      <span class="section-label">What We Do</span>
      <h2 class="section-title">Our Services</h2>
      <div class="accent-line"></div>
    </div>
    <div class="services-grid">
      <div class="service-card tilt-card">
        <div class="tilt-shine"></div>
        <div class="service-num">01</div>
        <div class="service-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.2"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6"/></svg>
        </div>
        <h3>Sale & Purchase</h3>
        <p>Complete assistance in buying and selling residential & commercial plots across all blocks in Al Jalil Garden Housing Scheme.</p>
        <a href="#contact" class="service-link">Get In Touch →</a>
        <div class="service-line"></div>
      </div>
      <div class="service-card tilt-card">
        <div class="tilt-shine"></div>
        <div class="service-num">02</div>
        <div class="service-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.2"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
        </div>
        <h3>Property Marketing</h3>
        <p>Strategic marketing campaigns to sell your property faster. We leverage our network of 1800+ clients for maximum exposure and best returns.</p>
        <a href="#contact" class="service-link">Get In Touch →</a>
        <div class="service-line"></div>
      </div>
      <div class="service-card tilt-card">
        <div class="tilt-shine"></div>
        <div class="service-num">03</div>
        <div class="service-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3>File Verification</h3>
        <p>Thorough verification of all property documentation and ownership history. We ensure every transaction is legally sound and fully transparent.</p>
        <a href="#contact" class="service-link">Get In Touch →</a>
        <div class="service-line"></div>
      </div>
      <div class="service-card tilt-card">
        <div class="tilt-shine"></div>
        <div class="service-num">04</div>
        <div class="service-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--blue-light)" stroke-width="1.2"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 000 20 14.5 14.5 0 000-20M2 12h20"/></svg>
        </div>
        <h3>Virtual Site Tours</h3>
        <p>Can't visit in person? Explore the complete Al Jalil Garden development through our immersive 360° virtual tour experience from anywhere.</p>
        <a href="http://myajdcloud.com/vtour/ajg.html" target="_blank" class="service-link">Take the Tour →</a>
        <div class="service-line"></div>
      </div>
    </div>
  </div>
</section>

<!-- ==================== VIRTUAL TOUR CTA ==================== -->
<section id="tour-cta">
  <div class="tour-cta-inner">
    <canvas id="tour-canvas"></canvas>
    <div class="tour-cta-bg"></div>
    <div class="tour-cta-content">
      <span class="section-label">Immersive Experience</span>
      <h2 class="section-title">Explore Al Jalil Garden in 360°</h2>
      <p class="section-desc" style="max-width:780px; margin: 0 auto 36px;">Walk through the streets, parks, and amenities of Al Jalil Garden without leaving your home. Our interactive virtual tour lets you experience every detail.</p>
      <a href="http://myajdcloud.com/vtour/ajg.html" target="_blank" class="btn btn-tour">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Launch Virtual Tour
      </a>
    </div>
  </div>
</section>

<!-- ==================== PROJECT ==================== -->
<section id="projects">
  <canvas id="projects-canvas"></canvas>
  <div class="section">
    <span class="section-label">Our Project</span>
    <h2 class="section-title">Al Jalil Garden Housing Scheme</h2>
    <div class="accent-line"></div>
    <div class="project-showcase">
      <div class="project-main">
        <div class="project-badge">LDA APPROVED</div>
        <p class="project-location">
