      pyRend.setPixelRatio(Math.min(window.devicePixelRatio, 1.0));
      pyRend.setClearColor(0x070e1a, 1);
      const sizePay = () => {
        const p = payCanvas.parentElement!;
        pyRend.setSize(p.clientWidth, p.clientHeight);
        pyCam.aspect = p.clientWidth / p.clientHeight;
        pyCam.updateProjectionMatrix();
      };
      sizePay();
      window.addEventListener('resize', sizePay);
      const fG = new THREE.BufferGeometry();
      const fC = 1500, fP = new Float32Array(fC*3), fCl = new Float32Array(fC*3);
      for (let i=0;i<fC;i++) {
        fP[i*3]=(Math.random()-.5)*80; fP[i*3+1]=(Math.random()-.5)*50; fP[i*3+2]=(Math.random()-.5)*80-20;
        const w=Math.random()>.75, g=!w&&Math.random()>.85;
        fCl[i*3]=w?.9:g?.82:.24; fCl[i*3+1]=w?.9:g?.66:.49; fCl[i*3+2]=w?.95:g?.26:.78;
      }
      fG.setAttribute('position',new THREE.BufferAttribute(fP,3));
      fG.setAttribute('color',new THREE.BufferAttribute(fCl,3));
      const pyFPts=new THREE.Points(fG,new THREE.PointsMaterial({size:.055,vertexColors:true,transparent:true,opacity:.9,sizeAttenuation:true,depthWrite:false}));
      pyScene.add(pyFPts);
