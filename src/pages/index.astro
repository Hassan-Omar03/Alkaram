  background: rgba(8, 18, 33, 0.48);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border-radius: 0;
  overflow: hidden;
  height: 56px;
  display: flex;
  align-items: center;
  border-top: 1px solid rgba(255,255,255,0.08);
}

