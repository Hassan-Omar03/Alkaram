---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Al Karam Real Estate - Your trusted real estate partner in Al Noor Orchard & Al Jalil Garden, Lahore. Authorized sub-dealer of Al Jalil Developers." />
  <meta name="keywords" content="Al Karam Real Estate, Al Jalil Garden, Al Noor Orchard, Lahore real estate, plots in Lahore, Al Jalil Developers" />
  <link rel="icon" type="image/x-icon" href="/images/logo.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Manrope:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Manrope:wght@300;400;500;600;700&display=swap" /></noscript>
  <title>{title}</title>
  <style>
    html, body { overflow-x: hidden !important; width: 100% !important; max-width: 100% !important; }
    html { }
    #cursor-dot, #cursor-ring {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      pointer-events: none !important;
      contain: strict !important;
      will-change: transform !important;
    }
    @media (max-width: 768px) {
      .hamburger {
        display: flex !important;
        z-index: 100000 !important;
        position: relative !important;
      }
    }
  </style>
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <div class="site-fixed-bg" aria-hidden="true"></div>
  <div class="site-page" style="overflow-x:hidden; width:100%;">
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
  </div>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/fixes.css';

  .skip-link {
    position: fixed;
    top: 10px;
    left: 12px;
    z-index: 3000;
    padding: 10px 14px;
    border-radius: 10px;
    background: rgba(7, 14, 26, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.24);
    color: #ffffff;
    letter-spacing: 0.4px;
    font-size: 0.82rem;
    transform: translateY(-170%);
    transition: transform 0.2s ease;
  }

  .skip-link:focus,
  .skip-link:focus-visible {
    transform: translateY(0);
    outline: none;
    box-shadow: 0 0 0 3px rgba(90, 157, 224, 0.35);
  }
</style>
